{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "dev",
      "runtimeExecutable": "sh",
      "runtimeArgs": ["-c", "exec python3 -m http.server $PORT"],
      "autoPort": true
    },
    {
      "name": "prod-dist",
      "runtimeExecutable": "sh",
      "runtimeArgs": [
        "-c",
        "exec python3 -m http.server --directory dist $PORT"
      ],
      "autoPort": true
    }
  ]
}
