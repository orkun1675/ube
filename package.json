{
  "name": "ube-landing",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "description": "Static landing for ube.dev. Local: open index.html. CI: npm run build.",
  "scripts": {
    "build": "node build.mjs",
    "lint": "biome check --write --unsafe --no-errors-on-unmatched --files-ignore-unknown=true ./",
    "check": "biome check --no-errors-on-unmatched --files-ignore-unknown=true ./"
  },
  "dependencies": {
    "@amplitude/unified": "^1.1.9"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.15",
    "esbuild": "^0.28.0"
  }
}
