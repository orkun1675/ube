---
// Nav.astro — global top navigation.
// `currentProduct` highlights the active product-switcher pill.
// "Publisher" and "Pricing" are greyed pre-launch.
import Wordmark from './Wordmark.astro';

interface Props {
  currentProduct?: 'maintainer' | 'publisher' | 'none';
}
const { currentProduct = 'maintainer' } = Astro.props;
---
<nav class="nav" id="nav">
  <div class="container nav-inner">
    <div class="nav-left">
      <Wordmark />
      <div class="nav-center">
        <div class="product-switcher">
          <a
            href="/"
            class={`ps-item${currentProduct === 'maintainer' ? ' active' : ''}`}
          >Maintainer</a>
          <span class="ps-item disabled">
            Publisher
            <span class="tip">Coming soon</span>
          </span>
        </div>
      </div>
    </div>
    <div class="nav-links">
      <span class="nav-link disabled">
        Pricing
        <span class="tip">Coming soon</span>
      </span>
      <button class="btn btn-primary btn-sm js-open-modal">Request Access</button>
    </div>
  </div>
</nav>
