---
// mockups/FixMockup.astro
// Step 3 visual — 3-pane composite: emulator, code diff, CI test results.
---
<div class="fix-comp">
  <div class="fix-head">
    <span class="id">issue #4821 · WidgetUnmount NPE</span>
    <span class="ind">Ube is fixing</span>
  </div>
  <div class="fix-body">
    {/* Emulator */}
    <div class="fix-pane">
      <div class="pane-label">Emulator · Pixel 7 · API 34</div>
      <div class="emu">
        <div class="emu-status">
          <span>9:41</span>
          <span>● ● ●</span>
        </div>
        <div class="emu-screen">
          <div class="emu-app-bar">YourApp</div>
          <div class="emu-content-row med"></div>
          <div class="emu-content-row short"></div>
          <div class="emu-content-row"></div>
          <div class="emu-content-row med"></div>
          <div class="emu-error-banner">! widget unmount crashed</div>
        </div>
        <div class="emu-nav">
          <span class="tri"></span>
          <span class="ci"></span>
          <span class="sq"></span>
        </div>
      </div>
      <div class="emu-caption">reproducing…  attempt 1/3</div>
    </div>

    {/* Diff */}
    <div class="fix-pane">
      <div class="pane-label">Diff · WidgetUnmount.kt</div>
      <div class="diff">
        <div class="diff-head">
          <span>src/widgets/WidgetUnmount.kt</span>
          <span class="lang">kotlin</span>
        </div>
        <div class="diff-lines">
          <div class="diff-line ctx"><span class="ln">85</span><span class="code">fun cleanup() {'{'}</span></div>
          <div class="diff-line del"><span class="ln">86</span><span class="code">  val view = widget.view</span></div>
          <div class="diff-line del"><span class="ln">87</span><span class="code">  view.onDetach()</span></div>
          <div class="diff-line add"><span class="ln">86</span><span class="code">  val view = widget.view ?: return</span></div>
          <div class="diff-line add"><span class="ln">87</span><span class="code">  view.onDetach()</span></div>
          <div class="diff-line ctx"><span class="ln">88</span><span class="code">  widget.release()</span></div>
          <div class="diff-line ctx"><span class="ln">89</span><span class="code">{'}'}</span></div>
        </div>
      </div>
    </div>

    {/* Tests */}
    <div class="fix-pane">
      <div class="pane-label">CI · regression suite</div>
      <div class="tests">
        <div class="tests-head">
          <span class="run-id">run #18421</span>
          <span style="color:var(--success)">● passing</span>
        </div>
        <div class="tests-body">
          <div class="test-row"><span class="check">✓</span><span class="name">WidgetUnmount · cleanup with null view</span><span class="ms">12ms</span></div>
          <div class="test-row"><span class="check">✓</span><span class="name">WidgetUnmount · cleanup normal path</span><span class="ms">8ms</span></div>
          <div class="test-row"><span class="check">✓</span><span class="name">Lifecycle · dispose order</span><span class="ms">34ms</span></div>
          <div class="test-row"><span class="check">✓</span><span class="name">Widget · render → unmount</span><span class="ms">21ms</span></div>
          <div class="test-row"><span class="check">✓</span><span class="name">e2e · video review tap flow</span><span class="ms">2.4s</span></div>
          <div class="test-summary"><span>regression suite</span><span>247 / 247</span></div>
        </div>
      </div>
    </div>
  </div>
</div>
