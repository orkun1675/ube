---
// mockups/TriageMockup.astro
// Step 2 visual — 4-column status board (New / Triaged / Obsolete / Muted).
const cols = [
  {
    title: 'New', count: 4,
    cards: [
      { sig: 'NPE @ WidgetUnmount.kt:87', meta: 'v2.4.1  ·  v2.4.2', tags: ['crash', 'android'] },
      { sig: 'TypeError @ VideoPlayer.tsx', meta: 'v2.4.2',           tags: ['rn', 'js'] },
    ],
  },
  {
    title: 'Triaged', count: 7,
    cards: [
      { sig: 'ANR @ MainActivity',     meta: 'v2.4.0–2.4.2', tags: ['anr'] },
      { sig: 'Camera stalls @ 5m',     meta: 'v2.4.1',       tags: ['camera', 'ios'] },
      { sig: 'Auth race on resume',    meta: 'v2.3.9+',      tags: ['auth'] },
    ],
  },
  {
    title: 'Obsolete', count: 12,
    cards: [
      { sig: 'Push token null @ APNS',   meta: 'fixed in v2.4.0', tags: ['shipped'] },
      { sig: 'White screen on cold start', meta: 'fixed in v2.3.8', tags: ['shipped'] },
    ],
  },
  {
    title: 'Muted', count: 3,
    cards: [
      { sig: 'Audio session unmount race', meta: 'expo-av@13.x', tags: ['up'], upstream: true },
    ],
  },
];
---
<div class="triage">
  {cols.map((c) => (
    <div class="triage-col">
      <h4>{c.title}<span class="ct">{c.count}</span></h4>
      {c.cards.map((card) => (
        <div class="t-card">
          <div class="t-sig">{card.sig}</div>
          <div class="t-meta">{card.meta}</div>
          <div class="t-tags">
            {card.tags.map((t) => (
              <span class={`t-tag${card.upstream && t === 'up' ? ' up' : ''}`}>{t === 'up' ? 'upstream' : t}</span>
            ))}
          </div>
        </div>
      ))}
    </div>
  ))}
</div>
