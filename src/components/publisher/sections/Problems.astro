---
import {
  BarChartIcon,
  GearIcon,
  LoopIcon,
  MegaphoneIcon,
  SparklesIcon,
} from "@/lib/assets"

type Card = {
  Icon: typeof GearIcon
  title: string
  body: string
}

const row1: Card[] = [
  {
    Icon: GearIcon,
    title: "Setup takes months.",
    body: "Three analytics SDKs. An MMP. An SKAdNetwork schema. Months of setup and debugging before your first ad goes live.",
  },
  {
    Icon: MegaphoneIcon,
    title: "Advertising is a full-time job.",
    body: "Meta, Google, TikTok, Reddit — each with its own dialect, billing, pixels, and quirks. Learning each one is a full-time job.",
  },
  {
    Icon: LoopIcon,
    title: "Growth is a feedback loop.",
    body: "Tune onboarding. Tune difficulty. Tune paywalls. All repetitive work, with a lot of waiting in between steps.",
  },
]

const row2: Card[] = [
  {
    Icon: SparklesIcon,
    title: "Ad creatives are relentless.",
    body: "Images, videos, playables, seasonal hooks. You need fresh creatives every month to keep customer acquisition costs low.",
  },
  {
    Icon: BarChartIcon,
    title: "Dashboards need code context.",
    body: "Twenty-character event names don't explain themselves. Without the engineer who wrote them in the room, everyone is guessing.",
  },
]
---

<section class="section publisher-problems">
  <div class="container">
    <div class="eyebrow">The problem</div>
    <h2 class="t-display-lg publisher-problems-headline">
      You shipped the app.{" "}
      <span class="publisher-problems-headline-accent">
        Now the hard part starts.
      </span>
    </h2>
    <p class="t-body-md body publisher-problems-intro">
      Building isn't the moat anymore. Distribution is. The gap between "it
      works" and "people use it" is where companies are won and lost.
    </p>

    <div class="grid-3 publisher-problems-grid">
      {
        row1.map(({ Icon, title, body }) => (
          <div class="card card-hover publisher-problem-card">
            <div class="publisher-problem-card-icon">
              <Icon size={26} />
            </div>
            <h3 class="t-title-md ink publisher-problem-card-title">{title}</h3>
            <p class="t-body-sm body publisher-problem-card-body">{body}</p>
          </div>
        ))
      }
    </div>

    <div class="publisher-problems-grid-secondary">
      {
        row2.map(({ Icon, title, body }) => (
          <div class="card card-hover publisher-problem-card">
            <div class="publisher-problem-card-icon">
              <Icon size={26} />
            </div>
            <h3 class="t-title-md ink publisher-problem-card-title">{title}</h3>
            <p class="t-body-sm body publisher-problem-card-body">{body}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  .publisher-problems {
    background: var(--canvas-soft);
    border-block: 1px solid var(--hairline-soft);
  }
  .publisher-problems-headline {
    margin: 18px 0 0;
    max-width: 880px;
  }
  .publisher-problems-headline-accent {
    color: var(--accent-2);
  }
  .publisher-problems-intro {
    margin: 24px 0 0;
    max-width: 640px;
    line-height: 1.65;
  }
  .publisher-problems-grid {
    margin-top: 64px;
    gap: 24px;
    grid-template-columns: repeat(3, 1fr);
  }
  /* The 3→2 collapse leaves an orphan, so jump straight to a single
     column once the layout can't hold all three across. */
  @media (max-width: 1024px) {
    .publisher-problems-grid {
      grid-template-columns: 1fr;
    }
  }

  /* Secondary row: two cards centered, matching the column width of the
     three-up grid above. Hidden once the main grid collapses. */
  .publisher-problems-grid-secondary {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 24px;
    margin: 24px auto 0;
    max-width: calc((100% * 2 - 24px) / 3);
  }
  @media (max-width: 1024px) {
    .publisher-problems-grid-secondary {
      display: none;
    }
  }

  .publisher-problem-card {
    padding: 32px;
  }
  .publisher-problem-card-icon {
    width: 50px;
    height: 50px;
    border-radius: 10px;
    background: var(--mark-tint);
    color: var(--mark);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 22px;
    border: 1px solid color-mix(in oklab, var(--mark) 25%, transparent);
  }
  .publisher-problem-card-title {
    margin-bottom: 10px;
  }
  .publisher-problem-card-body {
    margin: 0;
    line-height: 1.6;
  }
</style>
