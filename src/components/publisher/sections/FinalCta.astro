---
import { ArrowRightIcon } from "@phosphor-icons/react"
---

<section class="publisher-final">
  <div class="publisher-final-grid" aria-hidden="true"></div>
  <div class="container publisher-final-inner">
    <h2 class="t-display-lg">
      Let's grow your app together.
    </h2>
    <p class="t-body-md muted">
      Hand the distribution loop to Ube. Get back to building.
    </p>
    <button type="button" class="btn btn-primary" data-publisher-final-cta>
      Request access
      <ArrowRightIcon size={14} aria-hidden="true" />
    </button>
  </div>
</section>

<script src="./final-cta.client.ts"></script>

<style>
  .publisher-final {
    position: relative;
    overflow: hidden;
    padding: 136px 0;
    text-align: center;
    /* No top border — the CrossPromo band directly above shares this same
       `--canvas` surface and carries the hairline that separates the dark
       closing region from the lighter section above it. A border here would
       draw a seam between two intentionally-blended same-color bands. */
  }
  .publisher-final::before {
    content: "";
    position: absolute;
    inset: 0;
    background: radial-gradient(
      ellipse at center,
      rgba(107, 63, 160, 0.31),
      transparent 62%
    );
    pointer-events: none;
  }
  .publisher-final-grid {
    position: absolute;
    inset: 0;
    background-image: radial-gradient(
      rgba(255, 255, 255, 0.14) 1px,
      transparent 1px
    );
    background-size: 32px 32px;
    opacity: 0.55;
    pointer-events: none;
    mask-image: radial-gradient(
      ellipse 80% 62% at 50% 28%,
      #000 0%,
      transparent 76%
    );
    -webkit-mask-image: radial-gradient(
      ellipse 80% 62% at 50% 28%,
      #000 0%,
      transparent 76%
    );
  }
  .publisher-final-inner {
    position: relative;
    z-index: 1;
  }
  .publisher-final h2 {
    max-width: 820px;
    margin: 0 auto;
  }
  .publisher-final p {
    max-width: 620px;
    margin: 20px auto 32px;
  }
  @media (max-width: 640px) {
    .publisher-final {
      padding: 92px 0;
    }
  }
</style>
