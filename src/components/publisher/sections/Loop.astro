---
import { ArrowRightIcon } from "@phosphor-icons/react"
import AcquireMockup from "@/components/publisher/mockups/AcquireMockup.astro"
import AttributeMockup from "@/components/publisher/mockups/AttributeMockup.astro"
import InstrumentMockup from "@/components/publisher/mockups/InstrumentMockup.astro"
import MeasureMockup from "@/components/publisher/mockups/MeasureMockup.astro"
import MonetizeMockup from "@/components/publisher/mockups/MonetizeMockup.astro"
import RetainMockup from "@/components/publisher/mockups/RetainMockup.astro"

type Step = {
  num: string
  label: string
  title: string
  body: string
  learnMore: string
  disabled?: boolean
  reversed: boolean
}

const steps: Step[] = [
  {
    num: "01",
    label: "Instrument",
    reversed: true,
    title: "Analytics, wired up right.",
    body: "SDKs installed, user IDs aligned across platforms, and every event labeled in plain language. The result is a clean taxonomy you can understand months from now.",
    learnMore: "Why annotation order matters",
    disabled: true,
  },
  {
    num: "02",
    label: "Attribute",
    reversed: false,
    title: "Closes the feedback loop.",
    body: "MMP set up, SKAdNetwork configured, revenue forwarded to your ad networks. The full ad → click → install → in-app event chain, working end to end.",
    learnMore: "How attribution works",
    disabled: true,
  },
  {
    num: "03",
    label: "Measure",
    reversed: true,
    title: "Dashboards that mean something.",
    body: "D7, CAC, LTV, funnel drop-offs — readable in plain language. Internal users filtered out by default. The numbers you see are simple and actionable.",
    learnMore: "Picking metrics that matter",
    disabled: true,
  },
  {
    num: "04",
    label: "Acquire",
    reversed: false,
    title: "Runs and tunes your ads.",
    body: "Generates creatives, launches campaigns on Meta, Google, Reddit,and TikTok, and shifts budget toward the channel that has the best customer acquisition cost.",
    learnMore: "How creatives get made",
    disabled: true,
  },
  {
    num: "05",
    label: "Retain",
    reversed: true,
    title: "Spots drop-offs. Tests fixes.",
    body: "Reads your funnel, proposes an A/B test, ships it through Firebase Remote Config, calls the winner once it's statistically conclusive.",
    learnMore: "How we run A/B tests",
    disabled: true,
  },
  {
    num: "06",
    label: "Monetize",
    reversed: false,
    title: "Optimizes pricing.",
    body: "Tests price points and trial lengths via RevenueCat. Ad formats and placements via AdMob. Helps you monetize effectively without hurting retention.",
    learnMore: "When monetization matters",
    disabled: true,
  },
]
---

<section class="section loop-section" id="loop">
  <div class="container">
    <div class="eyebrow">The solution</div>
    <h2 class="t-display-lg publisher-section-title">
      Measure, iterate, then scale to millions.
    </h2>
    <p class="t-body-md body publisher-section-copy">
      Six steps from the v1 release to establishing recurring revenue.
      The loop runs daily to generate insights and recommendations.
    </p>
    <div class="publisher-steps">
      {
        steps.map((step) => (
          <article class={`card-band step-band ${step.reversed ? "reversed" : "normal"}`}>
            {!step.reversed && (
              <div class="step-visual">
                {step.num === "01" && <InstrumentMockup />}
                {step.num === "02" && <AttributeMockup />}
                {step.num === "03" && <MeasureMockup />}
                {step.num === "04" && <AcquireMockup />}
                {step.num === "05" && <RetainMockup />}
                {step.num === "06" && <MonetizeMockup />}
              </div>
            )}
            <div class="step-copy">
              <div class="step-kicker">
                <span class="step-num">{step.num}</span>
                <span class="eyebrow">{step.label}</span>
              </div>
              <h3 class="t-display-md ink">{step.title}</h3>
              <p class="t-body-md body">{step.body}</p>
              {step.disabled ? (
                <span
                  class="inline-link coming-soon"
                  aria-disabled="true"
                >
                  {step.learnMore}
                  <ArrowRightIcon size={12} aria-hidden="true" />
                  <span class="tooltip">Coming soon</span>
                </span>
              ) : (
                <button
                  type="button"
                  class="inline-link"
                  data-loop-step={`${step.num}-${step.label.toLowerCase()}`}
                  data-loop-title={step.label}
                >
                  {step.learnMore}
                  <ArrowRightIcon size={12} aria-hidden="true" />
                </button>
              )}
            </div>
            {step.reversed && (
              <div class="step-visual">
                {step.num === "01" && <InstrumentMockup />}
                {step.num === "02" && <AttributeMockup />}
                {step.num === "03" && <MeasureMockup />}
                {step.num === "04" && <AcquireMockup />}
                {step.num === "05" && <RetainMockup />}
                {step.num === "06" && <MonetizeMockup />}
              </div>
            )}
          </article>
        ))
      }
    </div>
  </div>
</section>

<script src="./loop.client.ts"></script>

<style>
  .loop-section {
    background: var(--canvas-soft);
    border-block: 1px solid var(--hairline-soft);
  }
  .publisher-section-title {
    margin: 18px 0 0;
    max-width: 840px;
  }
  .publisher-section-copy {
    margin: 24px 0 0;
    max-width: 640px;
    line-height: 1.65;
  }
  .publisher-steps {
    margin-top: 64px;
    display: flex;
    flex-direction: column;
    gap: 32px;
  }
  .step-band {
    display: grid;
    gap: 64px;
    align-items: center;
  }
  .step-band.reversed {
    grid-template-columns: minmax(0, 1fr) minmax(0, 1.2fr);
  }
  .step-band.normal {
    grid-template-columns: minmax(0, 1.2fr) minmax(0, 1fr);
  }
  .step-copy {
    min-width: 0;
  }
  .step-visual {
    min-width: 0;
  }
  .step-kicker {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 22px;
  }
  .step-copy h3 {
    margin-bottom: 20px;
    line-height: 1.15;
  }
  .step-copy p {
    margin: 0 0 22px;
    line-height: 1.65;
  }
  .step-copy .inline-link.coming-soon {
    opacity: 0.4;
  }
  @media (max-width: 1024px) {
    .step-band.reversed,
    .step-band.normal {
      grid-template-columns: 1fr;
      gap: 36px;
    }
    .step-visual {
      order: 2;
    }
    .step-copy {
      order: 1;
    }
  }
</style>
