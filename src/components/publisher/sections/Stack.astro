---
import StackMap from "@/components/publisher/mockups/StackMap.astro"
---

<section class="section stack-section">
  <div class="container stack-layout">
    <div>
      <div class="eyebrow">The stack</div>
      <h2 class="t-display-lg publisher-section-title">
        Ube is the orchestrator, not one more dashboard.
      </h2>
      <p class="t-body-md body publisher-section-copy">
        It uses the tools you would eventually need anyway. The difference is
        that Ube knows how your app is instrumented, where the events go,
        which campaigns use them, and which product experiments they are
        supposed to answer.
      </p>
    </div>
    <StackMap />
  </div>
</section>

<style>
  .stack-section {
    background: var(--canvas);
  }
  .stack-layout {
    display: grid;
    grid-template-columns: minmax(0, 0.82fr) minmax(420px, 1fr);
    gap: 56px;
    align-items: center;
  }
  .publisher-section-title {
    margin: 18px 0 0;
    max-width: 840px;
  }
  .publisher-section-copy {
    margin: 18px 0 0;
    max-width: 680px;
    line-height: 1.65;
  }
  @media (max-width: 1100px) {
    .stack-layout {
      grid-template-columns: 1fr;
    }
  }
</style>
