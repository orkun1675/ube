---
import StackMap from "@/components/publisher/mockups/StackMap.astro"
---

<section class="section stack-section">
  <div class="container stack-layout">
    <div>
      <div class="eyebrow">The stack</div>
      <h2 class="t-display-lg publisher-section-title">
        Ube is <em>the</em> orchestrator.
      </h2>
      <p class="t-body-md body publisher-section-copy">
        Under the hood, Ube runs the same 11 market-leading tools the top studios use.
        Because it knows your app, it is able to wire them optimally.
        When your app outgrows Ube, the distribution stack is yours to keep.
      </p>
    </div>
    <StackMap />
  </div>
</section>

<style>
  .stack-section {
    position: relative;
    background: var(--canvas);
    overflow: hidden;
    isolation: isolate;
  }
  .stack-layout {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: minmax(0, 0.82fr) minmax(420px, 1fr);
    gap: 56px;
    align-items: center;
  }
  .publisher-section-title {
    margin: 18px 0 0;
    max-width: 840px;
  }
  .publisher-section-copy {
    margin: 18px 0 0;
    max-width: 680px;
    line-height: 1.65;
  }
  @media (max-width: 1100px) {
    .stack-layout {
      grid-template-columns: 1fr;
    }
  }
</style>
