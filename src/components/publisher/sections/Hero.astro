---
import { ReactLogo } from "@/lib/assets"
import {
  ArrowRightIcon,
  PlantIcon,
  SparkleIcon,
} from "@phosphor-icons/react"
import WeeklyMockup from "@/components/publisher/mockups/WeeklyMockup.astro"
---

<section class="publisher-hero" id="top">
  <div class="publisher-hero-grid-bg" aria-hidden="true"></div>
  <div class="container publisher-hero-inner">
    <div class="publisher-hero-copy fade-in">
      <div class="eyebrow publisher-hero-eyebrow">Ube Publisher</div>
      <h1 class="t-display-mega publisher-hero-title">
        Everything you need
        <br />
        <span class="publisher-hero-title-muted">to distribute your app.</span>
      </h1>
      <p class="t-body-md body publisher-hero-body">
        All the market-leading growth tools top studios run on packaged for small teams.
        Months of complicated analytics set-up, testing, and advertising automated with AI.
      </p>
      <div class="publisher-cta-row">
        <button type="button" class="btn btn-primary" data-publisher-hero-cta>
          Request access
          <ArrowRightIcon size={14} aria-hidden="true" />
        </button>
        <a class="btn btn-secondary" href="#loop">See how it works</a>
      </div>
      <div class="publisher-builtfor">
        <span class="builtfor-label">Built for</span>
        <span class="builtfor-chip">
          <span class="builtfor-chip-mark" style="color: var(--accent)">
            <SparkleIcon size={12} aria-hidden="true" />
          </span>
          Vibecoders
        </span>
        <span class="builtfor-chip">
          <span class="builtfor-chip-mark" style="color: var(--success)">
            <PlantIcon size={12} aria-hidden="true" />
          </span>
          Solo founders
        </span>
        <span class="builtfor-chip">
          <span class="builtfor-chip-mark">
            <ReactLogo size={12} />
          </span>
          Indie studios
        </span>
      </div>
    </div>

    <div
      class="publisher-hero-visual fade-in"
      aria-label="Ube Publisher weekly brief mockup"
    >
      <WeeklyMockup />
    </div>
  </div>
</section>

<script src="./hero.client.ts"></script>

<style>
  .publisher-hero {
    position: relative;
    overflow: hidden;
    padding: 144px 0 176px;
    border-bottom: 1px solid var(--hairline-soft);
  }
  .publisher-hero-grid-bg {
    position: absolute;
    inset: 0;
    background-image: radial-gradient(
      rgba(255, 255, 255, 0.14) 1px,
      transparent 1px
    );
    background-size: 32px 32px;
    opacity: 0.55;
    pointer-events: none;
    mask-image: radial-gradient(
      ellipse 80% 62% at 50% 28%,
      #000 0%,
      transparent 76%
    );
    -webkit-mask-image: radial-gradient(
      ellipse 80% 62% at 50% 28%,
      #000 0%,
      transparent 76%
    );
  }
  .publisher-hero-inner {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 1.1fr 1fr;
    gap: 60px;
    align-items: center;
  }
  .publisher-hero-inner > * {
    min-width: 0;
  }
  .publisher-hero-eyebrow {
    margin-bottom: 28px;
  }
  .publisher-hero-title {
    margin: 0;
    color: var(--ink);
  }
  .publisher-hero-title-muted {
    color: var(--muted);
  }
  .publisher-hero-body {
    margin-top: 32px;
    max-width: 520px;
    line-height: 1.6;
  }
  .publisher-cta-row {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-top: 36px;
  }

  .publisher-builtfor {
    display: block;
    margin-top: 48px;
    color: var(--body);
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.6px;
    text-transform: uppercase;
  }
  .publisher-builtfor .builtfor-label,
  .publisher-builtfor .builtfor-chip {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    margin-right: 14px;
    margin-block: 6px;
    white-space: nowrap;
    vertical-align: middle;
  }
  .publisher-builtfor .builtfor-label {
    color: var(--muted);
    font-weight: 600;
    letter-spacing: 1.2px;
    margin-right: 18px;
  }
  .publisher-builtfor .builtfor-chip-mark {
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }

  .publisher-hero-visual {
    position: relative;
    min-width: 0;
  }

  @media (min-width: 1025px) {
    .publisher-hero-title {
      font-size: clamp(44px, 4.55vw, 58px);
      letter-spacing: -1.68px;
      line-height: 1.05;
      white-space: nowrap;
    }
    .publisher-hero-title-muted {
      white-space: nowrap;
    }
  }
  @media (max-width: 1100px) {
    .publisher-hero-inner {
      grid-template-columns: 1fr;
      gap: 56px;
    }
  }
  @media (max-width: 1024px) {
    .publisher-hero {
      padding: 104px 0 112px;
    }
  }
  @media (max-width: 640px) {
    .publisher-hero {
      padding: 80px 0 88px;
    }
    .publisher-hero-title br {
      display: none;
    }
  }
</style>
