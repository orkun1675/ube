---
// Cross-promo band — on the Publisher page, this surfaces the sibling
// product (Ube Maintainer). It sits in its own dark `--canvas` band that
// blends into the FinalCta band directly below it (same surface, no seam),
// so the two read as one closing region. Minimal content (a title + one CTA)
// framed in a gold-tinted card that pops against the dark band. The CTA is a
// plain `<a href="/maintainer/">`; the colocated `cross-promo.client.ts`
// fires a `cross_promo_clicked` analytics event before navigation so we can
// measure cross-product interest.
//
// Leans on the secondary "coconut" accent (--accent-2) so it reads as a
// distinct sibling product and doesn't compete with the white "Request
// access" button in the FinalCta band right below it.
import { ArrowRightIcon } from "@phosphor-icons/react"
---

<section class="xpromo">
  <div class="container">
    <div class="xpromo-card">
      <div class="xpromo-grid" aria-hidden="true"></div>
      <div class="xpromo-card-inner">
        <h2 class="t-display-md xpromo-title">Meet the other half of Ube</h2>
        <a
          class="xpromo-cta"
          href="/maintainer/"
          data-xpromo="publisher_to_maintainer"
        >
          Explore Ube Maintainer
          <ArrowRightIcon size={15} aria-hidden="true" />
        </a>
      </div>
    </div>
  </div>
</section>

<script src="./cross-promo.client.ts"></script>

<style>
  /* Its own dark band on the base `--canvas`, the same surface the FinalCta
     below sits on (FinalCta has no explicit background — just a radial glow
     over `--canvas`). FinalCta's top border is removed so the two same-color
     bands read as one continuous closing region; this band carries the
     `border-top` hairline that separates the dark region from Moat's lighter
     `--canvas-soft` surface above. */
  .xpromo {
    padding: 96px 0;
    background: var(--canvas);
    border-top: 1px solid var(--hairline-soft);
  }
  .xpromo-card {
    position: relative;
    overflow: hidden;
    max-width: 780px;
    margin: 0 auto;
    padding: 44px 48px;
    border-radius: var(--r-xl);
    background: linear-gradient(
      135deg,
      var(--accent-2-tint),
      var(--card-bg) 60%
    );
    border: 1px solid var(--card-border);
    isolation: isolate;
  }
  .xpromo-card::before {
    content: "";
    position: absolute;
    inset: 0;
    background: radial-gradient(
      ellipse 60% 130% at 100% 0%,
      var(--accent-2-tint),
      transparent 60%
    );
    pointer-events: none;
    z-index: -1;
  }
  .xpromo-grid {
    position: absolute;
    inset: 0;
    background-image: radial-gradient(
      rgba(255, 255, 255, 0.12) 1px,
      transparent 1px
    );
    background-size: 30px 30px;
    opacity: 0.4;
    pointer-events: none;
    z-index: -1;
    mask-image: radial-gradient(
      ellipse 55% 110% at 100% 0%,
      #000 0%,
      transparent 70%
    );
    -webkit-mask-image: radial-gradient(
      ellipse 55% 110% at 100% 0%,
      #000 0%,
      transparent 70%
    );
  }
  .xpromo-card-inner {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 32px;
  }
  .xpromo-title {
    margin: 0;
    max-width: 560px;
  }
  .xpromo-cta {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    flex-shrink: 0;
    height: 48px;
    padding: 0 24px;
    border-radius: var(--r-pill);
    border: 1px solid var(--accent-2);
    color: var(--accent-2);
    background: rgba(0, 0, 0, 0.12);
    font-family: var(--font-sans);
    font-size: 15px;
    font-weight: 600;
    text-decoration: none;
    white-space: nowrap;
    transition:
      background 160ms ease-out,
      color 160ms ease-out,
      transform 160ms ease-out;
  }
  .xpromo-cta:hover {
    background: var(--accent-2);
    color: var(--canvas);
    transform: translateY(-2px);
  }
  .xpromo-cta:focus-visible {
    outline: 2px solid var(--accent-2);
    outline-offset: 3px;
  }
  .xpromo-cta :global(svg) {
    transition: transform 160ms ease-out;
  }
  .xpromo-cta:hover :global(svg) {
    transform: translateX(4px);
  }
  @media (max-width: 720px) {
    .xpromo {
      padding: 64px 0;
    }
    .xpromo-card {
      padding: 36px 28px;
    }
    .xpromo-card-inner {
      flex-direction: column;
      align-items: flex-start;
      gap: 28px;
    }
  }
</style>
