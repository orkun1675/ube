---
import { Image } from "astro:assets"
import type { ImageMetadata } from "astro"
import beehive from "@/assets/customers/beehive.webp"
import dozy from "@/assets/customers/dozy.webp"
import pixelBuddy from "@/assets/customers/pixel-buddy.webp"

type FunnelStep = { step: string; value: number; pct: number }
const funnel: FunnelStep[] = [
  { step: "Install", value: 312, pct: 100 },
  { step: "Open", value: 232, pct: 74 },
  { step: "Sign up", value: 124, pct: 40 },
  { step: "Onboard", value: 118, pct: 38 },
]

type Customer = {
  src: ImageMetadata
  name: string
  metric: string
  delta: string
}
const customers: Customer[] = [
  { src: beehive, name: "Beehive", metric: "D7", delta: "+14%" },
  { src: dozy, name: "Dozy", metric: "CAC", delta: "-22%" },
  { src: pixelBuddy, name: "Pixel Buddy", metric: "LTV", delta: "+31%" },
]

const deltaTone = (metric: string, delta: string): "good" | "bad" => {
  if (delta.startsWith("-")) return metric === "CAC" ? "good" : "bad"
  return "good"
}
---

<div class="weekly-mockup" aria-label="Ube Publisher weekly brief mockup">
  <div class="mockup-chrome weekly-chrome">
    <div class="weekly-kpi-row">
      <div class="weekly-kpi">
        <div class="lbl mono">Learning budget</div>
        <div class="val">$20<span class="unit">/day</span></div>
      </div>
      <div class="weekly-kpi">
        <div class="lbl mono">Installs this week</div>
        <div class="val">312</div>
      </div>
      <div class="weekly-kpi">
        <div class="lbl mono">Best creative</div>
        <div class="val val-text">Finals week</div>
      </div>
    </div>

    <div class="weekly-rec">
      <div class="weekly-rec-head">
        <span class="lbl">Recommended next move</span>
        <span class="weekly-rec-tag mono">A/B TEST</span>
      </div>
      <div class="weekly-rec-title">
        Make sign up optional for the first session.
      </div>
      <div class="weekly-funnel">
        {
          funnel.map((f) => (
            <div class="weekly-funnel-row" style={`width: ${f.pct}%`}>
              <span class="step mono">{f.step}</span>
              <span class="val mono">{f.value}</span>
            </div>
          ))
        }
      </div>
    </div>

    <div class="weekly-approve">
      <span class="approve-dot" aria-hidden="true"></span>
      <span class="approve-text">
        Approve campaign launch on Google Ads + Meta?
      </span>
      <button type="button" class="approve-btn">Approve</button>
    </div>
  </div>

  <div class="weekly-customers">
    {
      customers.map((c) => (
        <div class="weekly-customer">
          <Image
            src={c.src}
            alt=""
            width={36}
            height={36}
            class="weekly-customer-logo"
            loading="eager"
          />
          <div class="weekly-customer-body">
            <div class="weekly-customer-name">{c.name}</div>
            <div class="weekly-customer-metric mono">
              <span class="m-lbl">{c.metric}</span>
              <span class={`m-delta ${deltaTone(c.metric, c.delta)}`}>
                {c.delta}
              </span>
            </div>
          </div>
        </div>
      ))
    }
  </div>
</div>

<style>
  .weekly-mockup {
    width: 100%;
    max-width: 560px;
    margin-left: auto;
  }
  .weekly-chrome {
    padding: 18px;
  }

  .weekly-kpi-row {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 10px;
    margin-bottom: 14px;
  }
  .weekly-kpi {
    background: var(--canvas);
    border: 1px solid var(--hairline);
    border-radius: var(--r-md);
    padding: 14px 14px 16px;
  }
  .weekly-kpi .lbl {
    font-size: 9.5px;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.6px;
    margin-bottom: 10px;
  }
  .weekly-kpi .val {
    color: var(--ink);
    font-size: 22px;
    font-weight: 500;
    letter-spacing: -0.4px;
    line-height: 1;
  }
  .weekly-kpi .val-text {
    font-size: 18px;
  }
  .weekly-kpi .val .unit {
    font-size: 13px;
    color: var(--muted);
    font-weight: 400;
    letter-spacing: 0;
    margin-left: 1px;
  }

  .weekly-rec {
    position: relative;
    background: var(--canvas);
    border: 1px solid var(--hairline);
    border-radius: var(--r-md);
    padding: 18px;
    margin-bottom: 12px;
  }
  .weekly-rec-head {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    margin-bottom: 8px;
  }
  .weekly-rec-head .lbl {
    flex: 1;
    font-size: 14px;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.8px;
    padding-top: 4px;
  }
  .weekly-rec-tag {
    background: var(--accent-tint);
    color: var(--accent);
    border: 1px solid color-mix(in oklab, var(--accent) 35%, transparent);
    border-radius: var(--r-pill);
    padding: 6px 12px;
    font-size: 9.5px;
    font-weight: 600;
    letter-spacing: 0.9px;
    line-height: 1;
    white-space: nowrap;
    flex-shrink: 0;
  }
  .weekly-rec-title {
    color: var(--ink);
    font-size: 24px;
    font-weight: 500;
    line-height: 1.25;
    letter-spacing: -0.5px;
    margin-bottom: 18px;
    max-width: 22em;
  }

  .weekly-funnel {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .weekly-funnel-row {
    position: relative;
    height: 30px;
    min-width: 110px;
    display: flex;
    align-items: center;
    padding: 0 12px;
    border: 1px solid color-mix(in oklab, var(--accent) 30%, transparent);
    border-radius: 6px;
    background: linear-gradient(
      90deg,
      color-mix(in oklab, var(--accent) 24%, transparent) 0%,
      color-mix(in oklab, var(--accent) 10%, transparent) 100%
    );
    font-size: 10.5px;
  }
  .weekly-funnel-row .step {
    color: var(--body);
  }
  .weekly-funnel-row .val {
    margin-left: auto;
    color: var(--ink);
    font-weight: 500;
  }

  .weekly-approve {
    display: flex;
    align-items: center;
    gap: 12px;
    background: var(--canvas);
    border: 1px solid var(--hairline);
    border-radius: var(--r-pill);
    padding: 8px 8px 8px 16px;
  }
  .approve-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--warning);
    flex-shrink: 0;
  }
  .approve-text {
    flex: 1;
    font-size: 12.5px;
    color: var(--body);
  }
  .approve-btn {
    background: var(--cta-fill);
    color: var(--cta-text);
    border: 0;
    border-radius: var(--r-pill);
    padding: 7px 16px;
    font-size: 12px;
    font-weight: 500;
    cursor: pointer;
    font-family: var(--font-sans);
  }
  .approve-btn:hover {
    background: var(--cta-fill-hover);
  }

  .weekly-customers {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 10px;
    margin-top: 14px;
  }
  .weekly-customer {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 12px;
    background: var(--surface-card);
    border: 1px solid var(--hairline-strong);
    border-radius: var(--r-md);
  }
  .weekly-customer-logo {
    width: 36px;
    height: 36px;
    border-radius: 8px;
    display: block;
    flex-shrink: 0;
  }
  .weekly-customer-body {
    display: flex;
    flex-direction: column;
    gap: 4px;
    min-width: 0;
  }
  .weekly-customer-name {
    color: var(--ink);
    font-size: 13px;
    font-weight: 600;
    line-height: 1;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .weekly-customer-metric {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 10.5px;
  }
  .weekly-customer-metric .m-lbl {
    color: var(--muted);
    letter-spacing: 0.4px;
  }
  .weekly-customer-metric .m-delta {
    color: var(--success);
    font-weight: 600;
    letter-spacing: 0.3px;
  }
  .weekly-customer-metric .m-delta.bad {
    color: var(--error);
  }

  @media (max-width: 1100px) {
    .weekly-mockup {
      margin-left: 0;
      max-width: 100%;
    }
  }
  @media (max-width: 640px) {
    .weekly-kpi-row {
      grid-template-columns: 1fr;
    }
    .weekly-customers {
      grid-template-columns: 1fr;
    }
  }
</style>
