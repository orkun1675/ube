---
import { PlusIcon, SparkleIcon } from "@phosphor-icons/react"
import { integrationLogos } from "@/lib/integration-logos"
---

<div class="mockup-chrome sdk-mockup">
  <div class="mockup-header">
    <span class="mono header-label">
      Diff · <span class="ink">lib/analytics/setup.dart</span>
    </span>
    <span class="spacer"></span>
    <span class="pill pill-accent">
      <SparkleIcon size={9} aria-hidden="true" /> AGENT EDIT
    </span>
  </div>
  <div class="code">
    <span class="diff-add">{"+ final trace = FirebasePerformance.instance"}</span>
    <span class="diff-add">{"+     .newTrace("}<span class="tok-str">{"'appStartup'"}</span>{")..start();"}</span>
    <span class="diff-add">{"+ trace.putAttribute("}<span class="tok-str">{"'first_open'"}</span>{", firstOpen ? "}<span class="tok-str">{"'true'"}</span>{" : "}<span class="tok-str">{"'false'"}</span>{");"}</span>
    <span class="diff-add">{"+ "}</span>
    <span class="diff-add">{"+ await AnalyticsConfig.init("}</span>
    <span class="diff-add">{"+   amplitudeApiKey: env.amplitudeKey,"}</span>
    <span class="diff-add">{"+   appsFlyerConfig: env.appsFlyer,"}</span>
    <span class="diff-add">{"+   clarityConfig: runningInBackground ? null : env.clarity,"}</span>
    <span class="diff-add">{"+   startupTrace: trace,"}</span>
    <span class="diff-add">{"+ );"}</span>
    <span class="diff-add">{"+ "}</span>
    <span class="diff-add">{"+ await Analytics.setConsent("}</span>
    <span class="diff-add">{"+   isPlaceholderValues: true,"}</span>
    <span class="diff-add">{"+   underAOC: true,"}</span>
    <span class="diff-add">{"+   hasConsent: false,"}</span>
    <span class="diff-add">{"+   requiresConsent: true,"}</span>
    <span class="diff-add">{"+ );"}</span>
  </div>
  <div class="instrument-footer">
    <span class="mono footer-label">IDs synced across</span>
    <img
      src={integrationLogos.firebase.src}
      alt=""
      width="14"
      height="14"
      loading="lazy"
    />
    <img
      src={integrationLogos.amplitude.src}
      alt=""
      width="14"
      height="14"
      loading="lazy"
    />
    <img
      src={integrationLogos.appsflyer.src}
      alt=""
      width="14"
      height="14"
      loading="lazy"
    />
    <img
      src={integrationLogos.clarity.src}
      alt=""
      width="14"
      height="14"
      loading="lazy"
    />
    <img
      src={integrationLogos.revenuecat.src}
      alt=""
      width="14"
      height="14"
      loading="lazy"
    />
    <span class="spacer"></span>
    <span class="pill pill-success">
      <PlusIcon size={9} aria-hidden="true" /> 18 EVENTS
    </span>
  </div>
</div>

<style>
  .sdk-mockup {
    min-width: 0;
  }
  .header-label {
    font-size: 11px;
    color: var(--muted);
  }
  .footer-label {
    font-size: 10.5px;
    color: var(--muted);
  }
  .spacer {
    flex: 1;
  }
  .code {
    padding: 14px 18px;
    font-family: var(--font-mono);
    font-size: 12px;
    line-height: 1.65;
    overflow-x: auto;
  }
  .code :global(.diff-add),
  .code :global(.diff-ctx) {
    white-space: pre;
  }
  .tok-str {
    color: #e8b76a;
  }
  .instrument-footer {
    padding: 10px 18px;
    border-top: 1px solid var(--hairline-soft);
    display: flex;
    align-items: center;
    gap: 10px;
    flex-wrap: wrap;
  }
  .instrument-footer img {
    flex-shrink: 0;
    display: block;
    object-fit: contain;
  }
  .instrument-footer :global(.pill) {
    margin-left: auto;
  }
  @media (max-width: 640px) {
    .code {
      font-size: 10px;
      line-height: 1.55;
      padding: 12px 14px;
      overflow-x: hidden;
    }
    .code :global(.diff-add),
    .code :global(.diff-ctx) {
      white-space: pre-wrap;
      word-break: break-word;
    }
  }
</style>
