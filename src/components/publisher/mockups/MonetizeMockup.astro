---
import { CheckIcon, SparkleIcon } from "@phosphor-icons/react"
import Term from "@/components/Term.astro"
import { integrationLogos } from "@/lib/integration-logos"
---

<div class="mockup-chrome">
  <div class="mockup-header">
    <span class="mono header-label">
      Paywall · <span class="ink">Pricing A/B</span>
    </span>
    <span class="spacer"></span>
    <img
      src={integrationLogos.revenuecat.src}
      alt="RevenueCat"
      width="14"
      height="14"
      loading="lazy"
    />
  </div>
  <div class="paywall-mockup">
    <div class="paywall-grid">
      <div class="paywall-variant">
        <span class="lbl mono">A · control</span>
        <div class="phone">
          <div class="phone-statusbar">
            <span class="phone-time mono">9:41</span>
            <span class="phone-notch"></span>
            <div class="phone-signal">
              <span class="bar"></span>
              <span class="bar"></span>
              <span class="bar"></span>
            </div>
          </div>
          <div class="phone-screen">
            <div class="phone-icon">
              <span>U</span>
            </div>
            <div class="phone-title">Unlock Pro</div>
            <ul class="phone-features">
              <li>
                <CheckIcon size={11} weight="bold" aria-hidden="true" />
                <span class="phone-feature-bar"></span>
              </li>
              <li>
                <CheckIcon size={11} weight="bold" aria-hidden="true" />
                <span class="phone-feature-bar"></span>
              </li>
              <li>
                <CheckIcon size={11} weight="bold" aria-hidden="true" />
                <span class="phone-feature-bar"></span>
              </li>
            </ul>
            <div class="phone-price">
              <span class="phone-price-amount mono">$9.99</span>
              <span class="phone-price-unit mono">/ mo</span>
            </div>
            <div class="phone-cta">Continue</div>
          </div>
        </div>
        <div class="paywall-stats">
          <div class="stat">
            <div class="l mono">Trial start</div>
            <div class="v mono">6.1 %</div>
          </div>
          <div class="stat">
            <div class="l mono"><Term term="arpu" /></div>
            <div class="v mono">$0.61</div>
          </div>
        </div>
      </div>
      <div class="paywall-variant winner">
        <span class="lbl mono">B · variant</span>
        <div class="phone phone-winner">
          <div class="phone-statusbar">
            <span class="phone-time mono">9:41</span>
            <span class="phone-notch"></span>
            <div class="phone-signal">
              <span class="bar"></span>
              <span class="bar"></span>
              <span class="bar"></span>
            </div>
          </div>
          <div class="phone-screen">
            <div class="phone-icon">
              <span>U</span>
            </div>
            <div class="phone-badge mono">3-day free trial</div>
            <div class="phone-title">Try Pro free</div>
            <ul class="phone-features">
              <li>
                <CheckIcon size={11} weight="bold" aria-hidden="true" />
                <span class="phone-feature-bar"></span>
              </li>
              <li>
                <CheckIcon size={11} weight="bold" aria-hidden="true" />
                <span class="phone-feature-bar"></span>
              </li>
              <li>
                <CheckIcon size={11} weight="bold" aria-hidden="true" />
                <span class="phone-feature-bar"></span>
              </li>
            </ul>
            <div class="phone-price phone-price-stacked">
              <span class="phone-price-strike mono">$9.99</span>
              <span>
                <span class="phone-price-amount mono">$4.99</span>
                <span class="phone-price-unit mono">/ mo</span>
              </span>
            </div>
            <div class="phone-cta">Start Trial</div>
          </div>
        </div>
        <div class="paywall-stats">
          <div class="stat win">
            <div class="l mono">Trial start</div>
            <div class="v mono">11.4 %</div>
          </div>
          <div class="stat win">
            <div class="l mono"><Term term="arpu" /></div>
            <div class="v mono">$0.94</div>
          </div>
        </div>
      </div>
    </div>
    <div class="paywall-suggest mono">
      <SparkleIcon size={12} aria-hidden="true" />
      <span class="paywall-suggest-prefix">Ube suggests:</span>
      <span>rollout variant B · expected lift +54 % <Term term="arpu" /></span>
    </div>
  </div>
</div>

<style>
  .header-label {
    font-size: 11px;
    color: var(--muted);
  }
  .spacer {
    flex: 1;
  }
  .paywall-mockup {
    padding: 18px;
  }
  .paywall-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 10px;
  }
  .paywall-variant {
    border: 1px solid var(--hairline);
    border-radius: var(--r-md);
    padding: 12px;
    background: var(--canvas);
    min-width: 0;
  }
  .paywall-variant.winner {
    border-color: color-mix(in oklab, var(--accent) 60%, transparent);
  }
  .paywall-variant .lbl {
    font-size: 9.5px;
    color: var(--muted);
    letter-spacing: 0.6px;
    text-transform: uppercase;
  }

  .phone {
    width: 172px;
    max-width: 100%;
    aspect-ratio: 9 / 16.8;
    margin: 10px auto 0;
    border: 1px solid color-mix(in oklab, var(--ink) 14%, transparent);
    border-radius: 28px;
    background: #101014;
    padding: 5px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    box-shadow:
      0 16px 32px rgb(0 0 0 / 0.22),
      inset 0 0 0 1px rgb(255 255 255 / 0.04);
  }
  .phone-winner {
    border-color: color-mix(in oklab, var(--accent) 45%, var(--hairline));
  }
  .phone-statusbar {
    position: relative;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 8px 14px 3px;
    border-radius: 22px 22px 0 0;
    background: var(--canvas);
    color: var(--ink);
  }
  .phone-time {
    font-size: 8.5px;
    font-weight: 600;
  }
  .phone-notch {
    position: absolute;
    left: 50%;
    top: 5px;
    transform: translateX(-50%);
    width: 34px;
    height: 6px;
    background: #08080a;
    border-radius: 999px;
  }
  .phone-signal {
    display: flex;
    align-items: flex-end;
    gap: 1.5px;
  }
  .phone-signal .bar {
    width: 2px;
    background: currentColor;
    border-radius: 1px;
    opacity: 0.7;
  }
  .phone-signal .bar:nth-child(1) {
    height: 3px;
  }
  .phone-signal .bar:nth-child(2) {
    height: 5px;
  }
  .phone-signal .bar:nth-child(3) {
    height: 7px;
  }
  .phone-screen {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 9px;
    min-height: 0;
    padding: 12px 13px 13px;
    border-radius: 0 0 22px 22px;
    background: var(--canvas);
    text-align: center;
  }
  .phone-icon {
    width: 42px;
    height: 42px;
    border-radius: 12px;
    background: linear-gradient(
      135deg,
      color-mix(in oklab, var(--accent) 65%, var(--ink)),
      color-mix(in oklab, var(--accent) 30%, var(--canvas))
    );
    display: grid;
    place-items: center;
    color: var(--ink);
    font-size: 18px;
    font-weight: 700;
    box-shadow: 0 8px 18px rgb(0 0 0 / 0.22);
  }
  .phone-badge {
    font-size: 8px;
    color: var(--accent);
    background: color-mix(in oklab, var(--accent) 14%, transparent);
    padding: 3px 8px;
    border-radius: 999px;
    text-transform: uppercase;
    letter-spacing: 0.4px;
    font-weight: 600;
  }
  .phone-title {
    font-size: 16px;
    font-weight: 600;
    color: var(--ink);
    line-height: 1.15;
  }
  .phone-features {
    list-style: none;
    padding: 0;
    margin: 2px 0 0;
    display: flex;
    flex-direction: column;
    gap: 6px;
    align-items: flex-start;
    color: var(--accent);
    width: 100%;
  }
  .phone-features li {
    display: flex;
    align-items: center;
    gap: 6px;
    line-height: 1.2;
  }
  .phone-feature-bar {
    display: block;
    height: 7px;
    border-radius: 999px;
    background: color-mix(in oklab, var(--ink) 24%, transparent);
  }
  .phone-features li:nth-child(1) .phone-feature-bar {
    width: 78px;
  }
  .phone-features li:nth-child(2) .phone-feature-bar {
    width: 98px;
  }
  .phone-features li:nth-child(3) .phone-feature-bar {
    width: 64px;
  }
  .phone-price {
    margin-top: 4px;
    display: flex;
    align-items: baseline;
    gap: 4px;
    flex-wrap: wrap;
    justify-content: center;
  }
  .phone-price-strike {
    color: var(--muted);
    text-decoration: line-through;
    font-size: 10.5px;
  }
  .phone-price-stacked {
    align-items: center;
    flex-direction: column;
    gap: 2px;
    line-height: 1.05;
  }
  .phone-price-amount {
    font-size: 19px;
    font-weight: 700;
    color: var(--ink);
  }
  .phone-price-unit {
    font-size: 10.5px;
    color: var(--muted);
  }
  .phone-cta {
    width: 100%;
    background: var(--accent);
    color: var(--ink);
    padding: 9px 10px;
    border-radius: 10px;
    font-size: 12px;
    font-weight: 700;
    margin-top: auto;
    text-align: center;
  }

  .paywall-stats {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 6px;
    margin-top: 12px;
  }
  .paywall-stats .stat .v {
    font-size: 12px;
    color: var(--ink);
  }
  .paywall-stats .stat.win .v {
    color: var(--success);
  }
  .paywall-stats .stat .l {
    font-size: 9px;
    color: var(--muted);
    letter-spacing: 0.5px;
    text-transform: uppercase;
  }
  .paywall-suggest {
    margin-top: 14px;
    padding: 10px 12px;
    border: 1px solid var(--hairline);
    background: var(--canvas);
    border-radius: 6px;
    font-size: 11px;
    color: var(--body);
    display: flex;
    align-items: center;
    gap: 8px;
    flex-wrap: wrap;
  }
  .paywall-suggest-prefix {
    color: var(--accent);
  }
  @media (max-width: 540px) {
    .paywall-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
