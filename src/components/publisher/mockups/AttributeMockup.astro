---
import {
  ArrowRightIcon,
  CurrencyDollarIcon,
  DownloadSimpleIcon,
  HandTapIcon,
  MegaphoneIcon,
} from "@phosphor-icons/react"

type Stage = {
  Icon: typeof MegaphoneIcon
  num: string
  label: string
}

const stages: Stage[] = [
  { Icon: MegaphoneIcon, num: "01", label: "Ad shown" },
  { Icon: DownloadSimpleIcon, num: "02", label: "Install" },
  { Icon: HandTapIcon, num: "03", label: "Engagement" },
  { Icon: CurrencyDollarIcon, num: "04", label: "Purchase" },
]
---

<div class="mockup-chrome">
  <div class="mockup-header">
    <span class="mono header-label">
      Attribution Loop · iOS · SKAdNetwork
    </span>
  </div>
  <div class="loop-mockup">
    <div class="stage-row">
      {
        stages.map((s, i) => (
          <>
            <div class="loop-stage">
              <span class="icon">
                <s.Icon size={18} aria-hidden="true" />
              </span>
              <span class="num">{s.num}</span>
              <span class="lbl">{s.label}</span>
            </div>
            {i < stages.length - 1 && (
              <span class="arrow-between" aria-hidden="true">
                <ArrowRightIcon size={14} weight="bold" />
              </span>
            )}
          </>
        ))
      }
    </div>
    <div class="loop-back" aria-hidden="true">
      <svg
        class="loop-back-svg"
        viewBox="0 0 600 60"
        preserveAspectRatio="none"
      >
        <defs>
          <marker
            id="loop-back-arrow"
            viewBox="0 0 10 10"
            refX="9"
            refY="3"
            markerWidth="7"
            markerHeight="7"
            orient="auto-start-reverse"
          >
            <path d="M0 0 L10 5 L0 10 Z" fill="var(--accent)"></path>
          </marker>
        </defs>
        <path
          d="M540 0 Q540 60 300 60 Q60 60 60 0"
          fill="none"
          stroke="var(--accent)"
          stroke-width="1.4"
          stroke-dasharray="5 4"
          marker-end="url(#loop-back-arrow)"
          opacity="0.85"></path>
      </svg>
    </div>
    <div class="loop-caption mono">loop closes · ad targeting improves</div>
  </div>
</div>

<style>
  .header-label {
    font-size: 11px;
    color: var(--muted);
  }
  .loop-mockup {
    position: relative;
    padding: 40px 32px 28px;
    background: var(--canvas);
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }
  .stage-row {
    display: flex;
    align-items: stretch;
    gap: 6px;
  }
  .loop-stage {
    background: var(--surface-card);
    border: 1px solid var(--hairline-strong);
    border-radius: var(--r-md);
    padding: 16px 10px;
    text-align: center;
    flex: 1 1 0;
    min-width: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  .loop-stage .icon {
    width: 32px;
    height: 32px;
    background: var(--mark-tint);
    color: var(--mark);
    border: 1px solid color-mix(in oklab, var(--mark) 25%, transparent);
    border-radius: 6px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 10px;
  }
  .loop-stage .num {
    font-family: var(--font-mono);
    font-size: 9px;
    color: var(--muted);
    letter-spacing: 0.5px;
    text-transform: uppercase;
    display: block;
  }
  .loop-stage .lbl {
    font-family: var(--font-mono);
    font-size: 10.5px;
    color: var(--ink);
    margin-top: 2px;
    display: block;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .arrow-between {
    display: inline-flex;
    align-items: center;
    color: var(--accent);
    flex: 0 0 auto;
    opacity: 0.85;
  }
  .loop-back {
    position: relative;
    height: 34px;
    margin-top: 0;
    overflow: visible;
  }
  .loop-back-svg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }
  .loop-caption {
    margin: 16px auto 0;
    display: inline-flex;
    align-items: center;
    align-self: center;
    width: fit-content;
    font-size: 10px;
    color: var(--ink);
    letter-spacing: 0.6px;
    text-transform: uppercase;
    background: var(--surface-card);
    padding: 5px 12px;
    border: 1px solid var(--hairline);
    border-radius: var(--r-pill);
  }
  @media (max-width: 760px) {
    .loop-mockup {
      padding: 28px 20px 22px;
    }
    .stage-row {
      flex-wrap: wrap;
      justify-content: center;
      gap: 10px;
    }
    .arrow-between {
      display: none;
    }
    .loop-stage {
      flex: 0 0 calc(50% - 10px);
    }
    .loop-back {
      display: none;
    }
  }
</style>
