---
import {
  ArrowRightIcon,
  ChartBarIcon,
  InfinityIcon,
  MegaphoneIcon,
  PlayCircleIcon,
} from "@phosphor-icons/react"

type Stage = {
  Icon: typeof MegaphoneIcon
  num: string
  label: string
}

const stages: Stage[] = [
  { Icon: MegaphoneIcon, num: "01", label: "Ad shown" },
  { Icon: ArrowRightIcon, num: "02", label: "Click" },
  { Icon: PlayCircleIcon, num: "03", label: "Install" },
  { Icon: ChartBarIcon, num: "04", label: "Event" },
  { Icon: InfinityIcon, num: "05", label: "Retargeted" },
]
---

<div class="mockup-chrome">
  <div class="mockup-header">
    <div class="traffic-lights"><span></span><span></span><span></span></div>
    <span class="mono header-label">
      attribution loop · <span class="ink">iOS · SKAdNetwork</span>
    </span>
    <span class="spacer"></span>
    <img
      src="/assets/integrations/appsflyer.svg"
      alt="AppsFlyer"
      width="14"
      height="14"
      loading="lazy"
    />
  </div>
  <div class="loop-mockup">
    <svg
      class="loop-svg"
      viewBox="0 0 600 200"
      preserveAspectRatio="none"
      aria-hidden="true"
    >
      <defs>
        <marker
          id="loop-arrow"
          viewBox="0 0 10 10"
          refX="9"
          refY="5"
          markerWidth="6"
          markerHeight="6"
          orient="auto-start-reverse"
        >
          <path d="M0 0 L10 5 L0 10 Z" fill="var(--accent)"></path>
        </marker>
      </defs>
      <line
        x1="80"
        x2="120"
        y1="80"
        y2="80"
        stroke="var(--accent)"
        stroke-width="1.2"
        stroke-dasharray="3 3"
        marker-end="url(#loop-arrow)"
        opacity="0.6"></line>
      <line
        x1="200"
        x2="240"
        y1="80"
        y2="80"
        stroke="var(--accent)"
        stroke-width="1.2"
        stroke-dasharray="3 3"
        marker-end="url(#loop-arrow)"
        opacity="0.6"></line>
      <line
        x1="320"
        x2="360"
        y1="80"
        y2="80"
        stroke="var(--accent)"
        stroke-width="1.2"
        stroke-dasharray="3 3"
        marker-end="url(#loop-arrow)"
        opacity="0.6"></line>
      <line
        x1="440"
        x2="480"
        y1="80"
        y2="80"
        stroke="var(--accent)"
        stroke-width="1.2"
        stroke-dasharray="3 3"
        marker-end="url(#loop-arrow)"
        opacity="0.6"></line>
      <path
        d="M540 110 Q540 180 300 180 Q60 180 60 110"
        fill="none"
        stroke="var(--accent)"
        stroke-width="1.2"
        stroke-dasharray="4 4"
        marker-end="url(#loop-arrow)"
        opacity="0.45"></path>
    </svg>
    <div class="stage-row">
      {
        stages.map((s) => (
          <div class="loop-stage">
            <span class="icon">
              <s.Icon size={16} aria-hidden="true" />
            </span>
            <span class="num">{s.num}</span>
            <span class="lbl">{s.label}</span>
          </div>
        ))
      }
    </div>
    <div class="loop-caption mono">loop closes · network gets feedback</div>
  </div>
</div>

<style>
  .header-label {
    font-size: 11px;
    color: var(--muted);
  }
  .spacer {
    flex: 1;
  }
  .loop-mockup {
    position: relative;
    padding: 32px 22px 22px;
    background: var(--canvas);
    overflow: hidden;
  }
  .loop-svg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    z-index: 1;
  }
  .stage-row {
    display: grid;
    grid-template-columns: repeat(5, minmax(0, 1fr));
    gap: 10px;
    position: relative;
    z-index: 2;
  }
  .loop-stage {
    background: var(--surface-card);
    border: 1px solid var(--hairline-strong);
    border-radius: var(--r-md);
    padding: 12px 10px;
    text-align: center;
    min-width: 0;
  }
  .loop-stage .icon {
    width: 28px;
    height: 28px;
    background: var(--mark-tint);
    color: var(--mark);
    border: 1px solid color-mix(in oklab, var(--mark) 25%, transparent);
    border-radius: 6px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 8px;
  }
  .loop-stage .num {
    font-family: var(--font-mono);
    font-size: 9px;
    color: var(--muted);
    letter-spacing: 0.5px;
    text-transform: uppercase;
    display: block;
  }
  .loop-stage .lbl {
    font-family: var(--font-mono);
    font-size: 10.5px;
    color: var(--ink);
    margin-top: 2px;
    display: block;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .loop-caption {
    margin: 18px auto 0;
    display: inline-flex;
    align-items: center;
    align-self: center;
    width: fit-content;
    font-size: 10px;
    color: var(--muted);
    letter-spacing: 0.6px;
    text-transform: uppercase;
    background: var(--surface-card);
    padding: 4px 10px;
    border: 1px solid var(--hairline);
    border-radius: var(--r-pill);
    position: relative;
    z-index: 3;
  }
  .loop-mockup {
    display: flex;
    flex-direction: column;
  }
  @media (max-width: 760px) {
    .stage-row {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
    .loop-svg {
      display: none;
    }
  }
</style>
