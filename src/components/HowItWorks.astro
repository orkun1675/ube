---
// HowItWorks.astro — the 5 alternating L/R card-bands.
// Each step composes a copy block + an imported mockup component.
import IntakeMockup     from './mockups/IntakeMockup.astro';
import TriageMockup     from './mockups/TriageMockup.astro';
import FixMockup        from './mockups/FixMockup.astro';
import TimelineMockup   from './mockups/TimelineMockup.astro';
import EscalationMockup from './mockups/EscalationMockup.astro';
---
<section class="section" id="how" style="background:var(--canvas-soft)">
  <div class="container">
    <div class="sec-head reveal">
      <div class="eyebrow">How it works</div>
      <h2 class="display-lg">Five steps, none of them yours.</h2>
      <p>Ube sits between your existing tools and your repo. It listens, decides, fixes, and reports — and tells you when it can't.</p>
    </div>

    <div class="steps">
      {/* 01 — Intake (visual right) */}
      <div class="step-band reveal">
        <div class="step-copy">
          <div class="step-indicator">
            <span class="step-num">01</span>
            <span class="step-name">Intake</span>
          </div>
          <h3 class="display-md step-title">Listen to every signal you already collect.</h3>
          <p class="step-desc">Ube hooks into your existing tools — Crashlytics, Sentry, Play Console ANRs, App Store reviews, support inboxes, and dependency upgrades — and treats each one as a possible issue to investigate.</p>
          <a href="#" class="plink">Learn about Intake →</a>
        </div>
        <div class="step-vis"><IntakeMockup /></div>
      </div>

      {/* 02 — Triage (visual left) */}
      <div class="step-band reverse reveal">
        <div class="step-copy">
          <div class="step-indicator">
            <span class="step-num">02</span>
            <span class="step-name">Triage</span>
          </div>
          <h3 class="display-md step-title">Group, track, and remember across versions.</h3>
          <p class="step-desc">Every signal is grouped into an issue with state — new, triaged, obsolete, muted. Ube tracks which binaries are affected, which dependencies are implicated, and whether there's an open upstream tracker. The same bug doesn't get rediscovered every sprint.</p>
          <a href="#" class="plink">Learn about Triage →</a>
        </div>
        <div class="step-vis"><TriageMockup /></div>
      </div>

      {/* 03 — Fix (visual right) */}
      <div class="step-band reveal">
        <div class="step-copy">
          <div class="step-indicator">
            <span class="step-num">03</span>
            <span class="step-name">Fix</span>
          </div>
          <h3 class="display-md step-title">Reproduce, patch, verify — before opening a PR.</h3>
          <p class="step-desc">Ube spins up an emulator, reproduces the bug, drafts a fix, runs your full test suite plus a regression suite, and only then opens a PR. You review the diff; nothing auto-merges unless you opt in.</p>
          <a href="#" class="plink">Learn about Fix →</a>
        </div>
        <div class="step-vis"><FixMockup /></div>
      </div>

      {/* 04 — Report success (visual left) */}
      <div class="step-band reverse reveal">
        <div class="step-copy">
          <div class="step-indicator">
            <span class="step-num">04</span>
            <span class="step-name">Report (success)</span>
          </div>
          <h3 class="display-md step-title">Close the loop with the user who reported it.</h3>
          <p class="step-desc">Once the fix lands in main, ships to beta, and rolls out to production, Ube tracks the release. Then it writes back to whoever filed the original report — the App Store reviewer, the support thread, the Crashlytics issue — so they know it shipped.</p>
          <a href="#" class="plink">Learn about Loop Closure →</a>
        </div>
        <div class="step-vis"><TimelineMockup /></div>
      </div>

      {/* 05 — Report failure (visual right) */}
      <div class="step-band reveal">
        <div class="step-copy">
          <div class="step-indicator">
            <span class="step-num">05</span>
            <span class="step-name">Report (failure)</span>
          </div>
          <h3 class="display-md step-title">When Ube can't fix it, you still get value.</h3>
          <p class="step-desc">Some bugs need a human, or live upstream in a dependency you don't own. Ube files a richly-documented upstream issue, links it to a tracking issue in your repo, and watches both until they move.</p>
          <a href="#" class="plink">Learn about Escalation →</a>
        </div>
        <div class="step-vis"><EscalationMockup /></div>
      </div>
    </div>
  </div>
</section>
