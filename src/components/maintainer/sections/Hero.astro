---
// Hero — static `.astro` markup rendered server-side (spec 0007). Replaces
// the previous `Hero` React island; the single interactive bit (the
// "Request access" CTA) is wired up by the colocated `hero.client.ts` to
// route into `openRequestAccess('hero')` from the shared nano store
// (preserving the analytics source label).
//
// `heroVariant` / `heroCopy` are read from `TWEAK_DEFAULTS` at build time
// and select the corresponding mockup + headline. The three mockup variants
// (`HeroPr`, `HeroMinimal`, `HeroSplit`) are now `.astro` themselves —
// rendering happens server-side with zero JS for the hero subtree (icons
// emit as inline SVG, just like Problems/Benefits/FinalCta).
//
// Layout-specific styling lives in the scoped <style> block at the bottom
// of this file (Astro auto-scopes per-component, so class names like
// `.hero-eyebrow` won't leak).
import { TWEAK_DEFAULTS } from "@/data/tweak-defaults"
import {
  AndroidLogo,
  AppleLogo,
  ArrowRight,
  ExpoLogo,
  FlutterLogo,
  ReactLogo,
} from "@/lib/assets"
import HeroMinimal from "@/components/maintainer/mockups/HeroMinimal.astro"
import HeroPr from "@/components/maintainer/mockups/HeroPr.astro"
import HeroSplit from "@/components/maintainer/mockups/HeroSplit.astro"

const heroVariant = TWEAK_DEFAULTS.heroVariant
const heroCopy = TWEAK_DEFAULTS.heroCopy
---

<section class="hero" id="top">
  <div class="hero-bg"></div>
  <div class="container hero-container">
    <div class="hero-grid">
      <div class="fade-in">
        <div class="eyebrow hero-eyebrow">
          Ube Maintainer
        </div>
        <h1 class="t-display-mega hero-headline">
          {
            heroCopy === "autopilot" ? (
              <>
                App maintenance, <br />
                <span class="hero-headline-muted">on autopilot.</span>
              </>
            ) : (
              <>
                An agent that <br />
                maintains your app <br />
                <span class="hero-headline-muted">
                  while you continue to build.
                </span>
              </>
            )
          }
        </h1>
        <p class="t-body-md body hero-body">
          Ube listens to your crash reports, user feedback, and dependency
          upgrades — then triages, reproduces, and opens verified PRs. You
          ship features. It handles the rest.
        </p>
        <div class="hero-cta-row">
          <button type="button" class="btn btn-primary" data-hero-cta>
            Request access
            <ArrowRight size={14} />
          </button>
          <a class="btn btn-secondary" href="#how">
            See how it works
          </a>
        </div>
        <div class="hero-builtfor">
          <span class="hero-builtfor__label">Built for</span>
          <span class="hero-builtfor__chip">
            <FlutterLogo size={14} /> Flutter
          </span>
          <span class="hero-builtfor__chip">
            <ReactLogo size={14} /> React Native
          </span>
          <span class="hero-builtfor__chip">
            <ExpoLogo size={14} /> Expo
          </span>
          <span class="hero-builtfor__chip">
            <AppleLogo size={14} /> iOS
          </span>
          <span class="hero-builtfor__chip">
            <AndroidLogo size={14} /> Android
          </span>
        </div>
      </div>
      <div class="fade-in hero-mockup-col">
        {heroVariant === "minimal" && <HeroMinimal />}
        {heroVariant === "split" && <HeroSplit />}
        {heroVariant !== "minimal" && heroVariant !== "split" && <HeroPr />}
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    padding: 120px 0 136px;
    overflow: hidden;
  }
  .hero-bg {
    position: absolute;
    inset: 0;
    background-image: radial-gradient(
      rgba(255, 255, 255, 0.16) 1px,
      transparent 1px
    );
    background-size: 32px 32px;
    opacity: 0.55;
    mask-image: radial-gradient(
      ellipse 80% 60% at 50% 30%,
      rgba(0, 0, 0, 1) 0%,
      transparent 70%
    );
    -webkit-mask-image: radial-gradient(
      ellipse 80% 60% at 50% 30%,
      rgba(0, 0, 0, 1) 0%,
      transparent 70%
    );
    pointer-events: none;
  }
  .hero-container {
    position: relative;
    z-index: 1;
  }
  .hero-grid {
    display: grid;
    grid-template-columns: 1.1fr 1fr;
    gap: 60px;
    align-items: center;
  }
  /* Grid children default to min-width:auto, which lets fixed-width inner
     content push the column wider than the parent. Force min-width:0 so
     1fr means "fit the container". */
  .hero-grid > * {
    min-width: 0;
  }
  .hero-eyebrow {
    margin-bottom: 28px;
  }
  .hero-headline {
    margin: 0;
    color: var(--ink);
  }
  .hero-headline-muted {
    color: var(--muted);
  }
  .hero-body {
    margin-top: 28px;
    max-width: 480px;
    line-height: 1.6;
  }
  .hero-cta-row {
    display: flex;
    gap: 12px;
    margin-top: 36px;
    flex-wrap: wrap;
  }

  /* "Built for" platform row — balance wrapping so we never orphan a single
     chip on its own line. Treat the row as inline text (block container with
     `text-wrap: balance`) and make each chip an inline-flex atom that can't
     break internally. The browser then distributes chips across lines to
     minimize ragged line lengths — same algorithm it uses for headings. */
  .hero-builtfor {
    display: block;
    text-wrap: balance;
    text-wrap-style: balance;
    line-height: 1;
    --bf-row-gap: 12px;
    padding-block: 2px;
    margin-top: 36px;
    color: var(--muted);
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.6px;
    text-transform: uppercase;
  }
  .hero-builtfor > .hero-builtfor__label,
  .hero-builtfor > .hero-builtfor__chip {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    margin-right: 16px;
    margin-block: calc(var(--bf-row-gap) / 2);
    white-space: nowrap;
    vertical-align: middle;
  }
  .hero-builtfor > :last-child {
    margin-right: 0;
  }

  .hero-mockup-col {
    animation-delay: 120ms;
  }

  /* The mockup chrome inside hero needs to go full-width on tablet/phone
     when the grid stacks. `.mockup-chrome` is a global primitive — wrap in
     :global() so Astro doesn't try to scope its selector. */
  @media (max-width: 1100px) {
    .hero-grid {
      grid-template-columns: 1fr;
      gap: 56px;
    }
    .hero :global(.mockup-chrome) {
      margin-left: 0;
      max-width: 100%;
    }
  }
  @media (max-width: 1024px) {
    .hero {
      padding: 96px 0 96px;
    }
  }
  @media (max-width: 640px) {
    .hero {
      padding: 72px 0 80px;
    }
    .hero-builtfor {
      font-size: 10.5px;
      --bf-row-gap: 10px;
    }
    .hero-builtfor > .hero-builtfor__label,
    .hero-builtfor > .hero-builtfor__chip {
      margin-right: 12px;
    }
  }
  @media (max-width: 480px) {
    .hero h1 br {
      display: none;
    }
  }
</style>

<script src="./hero.client.ts"></script>
