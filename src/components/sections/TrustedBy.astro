---
// TrustedBy — expo.dev-style logo marquee. Static markup; the marquee scroll
// is pure CSS animation (see .trusted-track in styles.css), no JS required.
//
// The original .tsx version computed the doubled sequence inside React.useMemo;
// here we precompute it at build time in the frontmatter — the output is
// identical bytes.
//
// Logos are imported via `astro:assets` so Astro can emit width/height
// attributes (no CLS) and hash-fingerprint the files for long-term caching.
import { Image } from "astro:assets"
import type { ImageMetadata } from "astro"
import alorma from "@/assets/customers/alorma.webp"
import beehive from "@/assets/customers/beehive.webp"
import blitzRush from "@/assets/customers/blitz-rush.webp"
import dozy from "@/assets/customers/dozy.webp"
import erun from "@/assets/customers/erun.webp"
import greenly from "@/assets/customers/greenly.webp"
import grinder from "@/assets/customers/grinder.webp"
import gymBuddies from "@/assets/customers/gym-buddies.webp"
import idelify from "@/assets/customers/idelify.webp"
import joinUp from "@/assets/customers/join-up.webp"
import joule from "@/assets/customers/joule.webp"
import localWeather from "@/assets/customers/local-weather.webp"
import orienteering from "@/assets/customers/orienteering.webp"
import paperMach from "@/assets/customers/paper-mach.webp"
import performa from "@/assets/customers/performa.webp"
import pixelBuddy from "@/assets/customers/pixel-buddy.webp"
import pixelQuest from "@/assets/customers/pixel-quest.webp"
import trink from "@/assets/customers/trink.webp"
import wordPlay from "@/assets/customers/word-play.webp"

type TrustedApp = { src: ImageMetadata; name: string }

const TRUSTED_APPS: TrustedApp[] = [
  { src: alorma, name: "Alorma — Sleep Sounds" },
  { src: beehive, name: "Beehive — Word Puzzle Challenge" },
  { src: blitzRush, name: "Blitz Rush — Endless Arcade Runner" },
  { src: dozy, name: "Dozy — Commute Companion" },
  { src: erun, name: "eRun — GPS Run Tracker" },
  { src: greenly, name: "Greenly — Plant Care Companion" },
  { src: grinder, name: "Grinder — Coffee Brew Guide" },
  { src: gymBuddies, name: "Gym Buddies — Workout Partner Finder" },
  { src: idelify, name: "Idelify — Page Layout Studio" },
  { src: joinUp, name: "Join Up — Group Messaging" },
  { src: joule, name: "Joule — Media Player" },
  { src: localWeather, name: "Local Weather — Hyperlocal Forecasts" },
  { src: orienteering, name: "Orienteering — Trail Navigation" },
  { src: paperMach, name: "Paper Mach — Notes & Docs" },
  { src: performa, name: "Performa — Performance Analytics" },
  { src: pixelBuddy, name: "Pixel Buddy — Coloring Book" },
  { src: pixelQuest, name: "Pixel Quest — Voxel Adventure" },
  { src: trink, name: "Trink — Hydration Tracker" },
  { src: wordPlay, name: "Word Play — Word Connect Game" },
]

// Repeat the full app set, then double the whole strip so translateX(-50%) loops seamlessly.
// 19 unique icons × 2 already overfills the widest viewports — more would just bloat the DOM.
const halfRepeats = 2
const half: TrustedApp[] = []
for (let i = 0; i < halfRepeats; i++) half.push(...TRUSTED_APPS)
const sequence: TrustedApp[] = [...half, ...half]
---

<section class="trusted-band" aria-label="Apps using Ube in production">
  <div class="trusted-band-grid" aria-hidden="true"></div>
  <div class="container trusted-label-row">
    <span class="trusted-label">Trusted in production by:</span>
  </div>
  <div class="trusted-marquee trusted-marquee-layered">
    <div class="trusted-track">
      {
        sequence.map((app) => (
          <div class="trusted-icon" title={app.name}>
            <Image
              src={app.src}
              alt={app.name}
              width={88}
              height={88}
              densities={[2, 3]}
              loading="lazy"
              draggable={false}
            />
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  /* Lift the label row and marquee above the absolutely-positioned grid
     backdrop (`.trusted-band-grid`). */
  .trusted-label-row {
    position: relative;
    z-index: 1;
  }
  .trusted-marquee-layered {
    position: relative;
    z-index: 1;
  }

  /* Trusted-in-production marquee (expo.dev-style social proof row).
     No top/bottom borders: the band is already set off by its lighter
     --canvas-soft surface and the dotted-grid fade. A --hairline-soft border
     is darker than --canvas, so against a same-tone (--canvas-soft) neighbor
     it reads as an ugly black line — let background contrast do the work. */
  .trusted-band {
    position: relative;
    padding: 80px 0 104px;
    background: var(--canvas-soft);
    overflow: hidden;
    isolation: isolate;
  }
  .trusted-band-grid {
    position: absolute;
    inset: 0;
    background-image: radial-gradient(
      rgba(255, 255, 255, 0.28) 1.2px,
      transparent 1.6px
    );
    background-size: 22px 22px;
    background-position: 0 0;
    opacity: 1;
    pointer-events: none;
    z-index: 0;
    mask-image: linear-gradient(
      to bottom,
      transparent 0%,
      #000 18%,
      #000 82%,
      transparent 100%
    );
    -webkit-mask-image: linear-gradient(
      to bottom,
      transparent 0%,
      #000 18%,
      #000 82%,
      transparent 100%
    );
  }
  .trusted-label {
    display: inline-block;
    color: var(--ink);
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 1.4px;
    text-transform: uppercase;
    margin: 0 0 44px 0;
    padding: 8px 18px;
    background: var(--canvas-soft);
    border-radius: var(--r-sm, 6px);
    position: relative;
    z-index: 2;
  }
  .trusted-band :global(.container):has(> .trusted-label) {
    text-align: center;
  }
  .trusted-marquee {
    position: relative;
    width: 100%;
    overflow: hidden;
    /* aggressive edge fade — icons fully disappear well before the screen edge */
    -webkit-mask-image: linear-gradient(
      to right,
      transparent 12%,
      #000 17%,
      #000 83%,
      transparent 88%
    );
    mask-image: linear-gradient(
      to right,
      transparent 12%,
      #000 17%,
      #000 83%,
      transparent 88%
    );
  }
  .trusted-track {
    display: flex;
    align-items: center;
    gap: 28px;
    width: max-content;
    animation: trusted-scroll 54s linear infinite;
    will-change: transform;
  }
  @keyframes trusted-scroll {
    from {
      transform: translateX(0);
    }
    to {
      transform: translateX(-50%);
    }
  }
  .trusted-icon {
    width: 88px;
    height: 88px;
    flex-shrink: 0;
    border-radius: 22px; /* iOS-app-icon squircle approximation */
    background: var(--surface-card);
    border: 1px solid var(--hairline);
    overflow: hidden;
    position: relative;
    box-shadow:
      0 1px 0 rgba(255, 255, 255, 0.04) inset,
      0 8px 24px rgba(0, 0, 0, 0.35);
  }
  .trusted-icon img {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
  }
  .trusted-icon::after {
    /* subtle inner ring like iOS app icons */
    content: "";
    position: absolute;
    inset: 0;
    border-radius: inherit;
    pointer-events: none;
    box-shadow: 0 0 0 1px rgba(255, 255, 255, 0.06) inset;
  }
  @media (max-width: 768px) {
    .trusted-band {
      padding: 64px 0 80px;
    }
    .trusted-marquee {
      -webkit-mask-image: linear-gradient(
        to right,
        transparent 0%,
        #000 5%,
        #000 95%,
        transparent 100%
      );
      mask-image: linear-gradient(
        to right,
        transparent 0%,
        #000 5%,
        #000 95%,
        transparent 100%
      );
    }
    .trusted-icon {
      width: 72px;
      height: 72px;
      border-radius: 18px;
    }
    .trusted-track {
      gap: 20px;
      animation-duration: 42s;
    }
    .trusted-band-grid {
      background-size: 20px 20px;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .trusted-track {
      animation: none;
      justify-content: center;
      flex-wrap: wrap;
      width: 100%;
    }
  }
  @media (max-width: 640px) {
    .trusted-label {
      font-size: 10px;
      padding: 6px 14px;
      margin-bottom: 28px;
    }
  }
</style>
