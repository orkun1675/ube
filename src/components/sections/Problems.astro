---
// Problems — static "THE PROBLEM" section with 3 content cards.
// Icons are React components rendered server-side with no client:* directive,
// so they ship as inline SVG with zero JS.
import { ClockIcon, FlaskIcon, StackIcon } from "../../lib/assets"

type Card = {
  Icon: typeof FlaskIcon
  title: string
  body: string
}

const cards: Card[] = [
  {
    Icon: FlaskIcon,
    title: "Tests get skipped.",
    body: 'Engineers read the stacktrace or eyeball the migration doc. They ship "simple fixes" without proper QA. The bug survives the release and results in customer churn.',
  },
  {
    Icon: StackIcon,
    title: "Unfixable bugs pile up.",
    body: "Dependency issues, hardware specific edge cases, intermittent crashes — all require hours of debugging. And when the root cause is upstream, filing a proper bug report is rarely worth the effort.",
  },
  {
    Icon: ClockIcon,
    title: "Maintenance delays releases.",
    body: "Internal testers find a missing null check moments before release. Engineering gets pulled back in. The exciting feature you actually shipped this sprint slips to next.",
  },
]
---

<section class="section problems-section">
  <div class="container">
    <div class="eyebrow problems-eyebrow">
      THE PROBLEM
    </div>
    <h2 class="t-display-lg problems-headline">
      App maintenance is{" "}
      <span class="problems-headline-accent">cumbersome.</span>
    </h2>
    <div class="grid-3 problems-grid">
      {
        cards.map(({ Icon, title, body }) => (
          <div class="card card-hover problems-card">
            <div class="problems-card-icon">
              <Icon size={26} />
            </div>
            <h3 class="t-title-md ink problems-card-title">
              {title}
            </h3>
            <p class="t-body-sm body problems-card-body">
              {body}
            </p>
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  .problems-section {
    background: var(--canvas);
  }
  .problems-eyebrow {
    margin-bottom: 18px;
  }
  .problems-headline {
    margin: 0;
    max-width: 760px;
  }
  .problems-headline-accent {
    color: var(--accent-2);
  }
  /* Problems uses exactly 3 cards — going 3→2 leaves an orphan in row 2.
     Jump straight from 3 cols → 1 col so the cards stay balanced. */
  .problems-grid {
    grid-template-columns: repeat(3, 1fr);
    margin-top: 56px;
  }
  @media (max-width: 1024px) {
    .problems-grid {
      grid-template-columns: 1fr;
    }
  }
  .problems-card {
    padding: 28px;
  }
  .problems-card-icon {
    width: 50px;
    height: 50px;
    border-radius: 10px;
    background: var(--mark-tint);
    color: var(--mark);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 22px;
    border: 1px solid color-mix(in oklab, var(--mark) 25%, transparent);
  }
  .problems-card-title {
    margin-bottom: 10px;
  }
  .problems-card-body {
    margin: 0;
    line-height: 1.6;
  }
</style>
