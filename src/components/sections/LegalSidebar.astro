---
// =====================================================================
//  LegalSidebar — shared sidebar nav for /terms-of-service/ and /privacy-policy/
// =====================================================================
// Both legal pages render an identical sidebar with two links and an
// `active` highlight for the current page. The `active` prop picks which
// link gets the highlight; everything else (markup, styles in styles.css)
// stays as it was.
export interface Props {
  active: "terms" | "privacy"
}

const { active } = Astro.props
---

<aside class="legal-sidebar">
  <nav class="legal-nav" aria-label="Legal pages">
    <a
      href="/terms-of-service/"
      class:list={[{ active: active === "terms" }]}
    >
      Terms of Service
    </a>
    <a
      href="/privacy-policy/"
      class:list={[{ active: active === "privacy" }]}
    >
      Privacy Policy
    </a>
  </nav>
</aside>

<style>
  .legal-sidebar {
    position: sticky;
    top: 96px;
  }
  .legal-nav {
    display: flex;
    flex-direction: column;
    gap: 14px;
  }
  .legal-nav a {
    color: var(--muted);
    text-decoration: none;
    font-size: 15px;
    font-weight: 450;
    transition: color 120ms ease-out;
  }
  .legal-nav a:hover {
    color: var(--body);
  }
  .legal-nav a.active {
    color: var(--ink);
  }
  @media (max-width: 900px) {
    .legal-sidebar {
      position: static;
      top: auto;
    }
    .legal-nav {
      flex-direction: row;
      gap: 24px;
      padding-bottom: 16px;
      border-bottom: 1px solid var(--hairline-soft);
    }
  }
</style>
