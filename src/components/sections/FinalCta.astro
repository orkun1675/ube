---
// Final CTA band — static `.astro` markup rendered server-side (spec 0006).
// Replaces the previous `FinalCTA` React island; the only real behavior is a
// single "Request access" button click, attached by the colocated
// `final-cta.client.ts` so it routes into `openRequestAccess('final_cta')`
// from the nano store (preserving the analytics source label).
//
// `ArrowRight` is a React icon component but renders here with no `client:*`
// directive — Astro emits it as inline SVG with zero JS, matching how the
// other static sections (Problems, Benefits) reuse icons from lib/assets.
import { ArrowRight } from "../../lib/assets"
---

<section class="cta-band">
  <div class="cta-band-bg"></div>
  <div class="cta-band-grid"></div>
  <div class="container cta-band-inner">
    <h2 class="t-display-lg cta-band-headline">
      Stop shipping fixes.
      <br />
      Start shipping features.
    </h2>
    <p class="t-body-md muted cta-band-subhead">
      Ube handles the maintenance loop so you can spend your sprint on what
      users actually asked for.
    </p>
    <button type="button" class="btn btn-primary" data-final-cta>
      Request access
      <ArrowRight size={14} />
    </button>
  </div>
</section>

<script src="./final-cta.client.ts"></script>

<style>
  .cta-band {
    position: relative;
    padding: 160px 0;
    overflow: hidden;
    border-top: 1px solid var(--hairline-soft);
    border-bottom: 1px solid var(--hairline-soft);
    isolation: isolate;
  }
  .cta-band-bg {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(
        ellipse at center,
        rgba(107, 63, 160, 0.32) 0%,
        rgba(107, 63, 160, 0.08) 35%,
        transparent 70%
      ),
      var(--canvas);
    z-index: -2;
  }
  .cta-band-grid {
    position: absolute;
    inset: 0;
    background-image: radial-gradient(
      rgba(255, 255, 255, 0.14) 1px,
      transparent 1px
    );
    background-size: 32px 32px;
    opacity: 0.5;
    mask-image: radial-gradient(
      ellipse at center,
      rgba(0, 0, 0, 1) 0%,
      rgba(0, 0, 0, 0.4) 50%,
      transparent 80%
    );
    -webkit-mask-image: radial-gradient(
      ellipse at center,
      rgba(0, 0, 0, 1) 0%,
      rgba(0, 0, 0, 0.4) 50%,
      transparent 80%
    );
    z-index: -1;
  }
  .cta-band-inner {
    position: relative;
    text-align: center;
  }
  .cta-band-headline {
    margin: 0 auto 18px;
    max-width: 720px;
  }
  .cta-band-subhead {
    margin: 0 auto 32px;
    max-width: 560px;
  }
  @media (max-width: 640px) {
    .cta-band {
      padding: 88px 0;
    }
    .cta-band :global(.t-display-lg) br {
      display: none;
    }
  }
</style>
