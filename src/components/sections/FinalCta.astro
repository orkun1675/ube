---
// Final CTA band — static `.astro` markup rendered server-side (spec 0006).
// Replaces the previous `FinalCTA` React island; the only real behavior is a
// single "Request access" button click, attached by the colocated
// `final-cta.client.ts` so it routes into `openRequestAccess('final_cta')`
// from the nano store (preserving the analytics source label).
//
// `ArrowRight` is a React icon component but renders here with no `client:*`
// directive — Astro emits it as inline SVG with zero JS, matching how the
// other static sections (Problems, Benefits) reuse icons from lib/assets.
import { ArrowRight } from "../../lib/assets"
---

<section class="cta-band">
  <div class="cta-band-bg"></div>
  <div class="cta-band-grid"></div>
  <div class="container cta-band-inner">
    <h2 class="t-display-lg cta-band-headline">
      Stop shipping fixes.
      <br />
      Start shipping features.
    </h2>
    <p class="t-body-md muted cta-band-subhead">
      Ube handles the maintenance loop so you can spend your sprint on what
      users actually asked for.
    </p>
    <button type="button" class="btn btn-primary" data-final-cta>
      Request access
      <ArrowRight size={14} />
    </button>
  </div>
</section>

<script src="./final-cta.client.ts"></script>

<style>
  .cta-band-inner {
    position: relative;
    text-align: center;
  }
  .cta-band-headline {
    margin: 0 auto 18px;
    max-width: 720px;
  }
  .cta-band-subhead {
    margin: 0 auto 32px;
    max-width: 560px;
  }
</style>
