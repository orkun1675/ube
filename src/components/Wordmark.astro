---
// Wordmark.astro — `ube` lockup with the ube-purple accent dot.
// Used in nav, footer, and anywhere we need the brand mark.
interface Props {
  href?: string;
  ariaLabel?: string;
}
const { href = '/', ariaLabel = 'Ube' } = Astro.props;
---
<a href={href} class="wordmark" aria-label={ariaLabel}>ube<span class="dot"></span></a>
