---
export interface Props {
  size?: number
}

const { size = 30 } = Astro.props
const sizeVar = `--wm-size: ${size}px`
---

<span class="wordmark" style={sizeVar}>
  <span class="wm-bracket wm-bracket-l" aria-hidden="true"></span>
  <span class="wm-word">ube</span>
  <span class="wm-bracket wm-bracket-r" aria-hidden="true"></span>
</span>

<style>
  .wordmark {
    font-family: var(--font-sans);
    font-size: var(--wm-size);
    font-weight: 600;
    letter-spacing: -0.5px;
    color: var(--ink);
    display: inline-flex;
    align-items: center;
    gap: 3px;
    position: relative;
    line-height: 1;
  }
  .wm-word {
    display: inline-block;
  }
  .wm-bracket {
    display: inline-block;
    width: 5px;
    height: 0.88em;
    border: 2.5px solid var(--accent);
    transform: translateY(0.02em);
  }
  .wm-bracket-l {
    border-right: none;
  }
  .wm-bracket-r {
    border-left: none;
  }
</style>
