---
// Footer — static markup rendered on every page. Lives in BaseLayout.astro.
// Reads wordmarkAccent from TWEAK_DEFAULTS so the brand mark in the footer
// matches the tweak panel's saved default at build time.
//
// Wordmark is now an `.astro` component (slice 0004) — same DOM as before,
// just hoisted out of `sections/` and consumed natively here.
import Wordmark from "@/components/Wordmark.astro"
import { CONTACT_EMAIL, GITHUB_URL, LINKEDIN_URL } from "@/constants"
import { TWEAK_DEFAULTS } from "@/data/tweak-defaults"
import { EnvelopeIcon } from "@phosphor-icons/react"
import { GitHubLogo, LinkedInLogo } from "@/lib/assets"

const wordmarkAccent = TWEAK_DEFAULTS.wordmarkAccent
---

<footer class="footer">
  <div class="container">
    <div class="footer-grid">
      <div class="footer-col">
        <Wordmark accent={wordmarkAccent} size={24} />
        <p class="t-body-sm muted footer-tagline">
          Your app's agentic watchdog that keeps dependencies up to date and
          users happy.
        </p>
        <p class="t-caption muted footer-copyright">
          © 2026 Ube · Chunky Tofu Studios, LLC
        </p>
      </div>
      <div class="footer-col">
        <h3>PRODUCTS</h3>
        <ul>
          <li>
            <a href="#how">Ube Maintainer</a>
          </li>
          <li>
            <span class="coming-soon">
              Ube Publisher
              <span class="tooltip">Coming soon</span>
            </span>
          </li>
          <li>
            <span class="coming-soon">
              Pricing
              <span class="tooltip">Coming soon</span>
            </span>
          </li>
        </ul>
      </div>
      <div class="footer-col">
        <h3>Legal</h3>
        <ul>
          <li>
            <a href="/terms-of-service/">Terms of Service</a>
          </li>
          <li>
            <a href="/privacy-policy/">Privacy Policy</a>
          </li>
        </ul>
      </div>
      <div class="footer-col">
        <h3>Contact</h3>
        <ul>
          <li>
            <a href={`mailto:${CONTACT_EMAIL}`} class="footer-contact-link">
              <EnvelopeIcon size={14} aria-hidden="true" /> {CONTACT_EMAIL}
            </a>
          </li>
          <li>
            <a
              href={LINKEDIN_URL}
              target="_blank"
              rel="noopener noreferrer"
              class="footer-contact-link"
            >
              <LinkedInLogo size={13} /> Orkun Duman
            </a>
          </li>
          <li>
            <a
              href={GITHUB_URL}
              target="_blank"
              rel="noopener noreferrer"
              class="footer-contact-link"
            >
              <GitHubLogo size={13} /> github.com/orkun1675/ube
            </a>
          </li>
        </ul>
      </div>
    </div>
  </div>
</footer>

<style>
  .footer {
    border-top: 1px solid var(--hairline-soft);
    padding: 64px 0 48px;
    background: var(--canvas);
  }
  .footer-grid {
    display: grid;
    grid-template-columns: 1.4fr 1fr 1fr 1fr;
    gap: 48px;
  }
  .footer-col h3 {
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.88px;
    text-transform: uppercase;
    color: var(--muted);
    margin: 0 0 18px 0;
    font-family: var(--font-mono);
  }
  .footer-col ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .footer-col a {
    color: var(--body);
    text-decoration: none;
    font-size: 14px;
  }
  .footer-col a:hover {
    color: var(--ink);
  }
  /* `.coming-soon` and `.tooltip` are global utility classes — wrap in
     :global() so the descendant selectors continue to match (they don't
     get this component's cid attribute). */
  .footer-col :global(.coming-soon) {
    font-size: 14px;
  }
  .footer-col :global(.tooltip) {
    top: auto;
    bottom: calc(100% + 8px);
    transform: translate(-50%, 4px);
  }
  .footer-col :global(.coming-soon):hover :global(.tooltip) {
    transform: translate(-50%, 0);
  }

  .footer-tagline {
    margin-top: 18px;
    max-width: 320px;
    line-height: 1.6;
  }
  .footer-copyright {
    margin-top: 24px;
  }
  .footer-contact-link {
    display: inline-flex;
    align-items: center;
    gap: 8px;
  }

  @media (max-width: 768px) {
    .footer-grid {
      grid-template-columns: 1fr;
      gap: 32px;
    }
  }
  @media (max-width: 640px) {
    .footer {
      padding: 48px 0 32px;
    }
    .footer-grid {
      gap: 28px;
    }
  }
</style>
