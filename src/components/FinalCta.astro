---
// FinalCta.astro — atmospheric ube-purple radial band before the footer.
// Pass `headline` and `body` to customize per page; defaults are the
// homepage copy.
interface Props {
  headline?: string;
  body?: string;
}
const {
  headline = 'Ready to stop maintaining and start building?',
  body = "We're opening early access to a small set of mobile teams. Tell us what you're shipping and we'll be in touch.",
} = Astro.props;
---
<section class="final-cta">
  <div class="container">
    <h2 class="display-lg" set:html={headline.replace(' and ', '<br>and ')}></h2>
    <p>{body}</p>
    <button class="btn btn-primary js-open-modal">Request Access</button>
  </div>
</section>
