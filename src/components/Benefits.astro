---
// Benefits.astro — hero stat (10–30%) + 6-up outcomes grid.
const benefits = [
  {
    icon: 'clock',
    title: '10–30% engineering time reclaimed.',
    desc: "Stop spending a third of every sprint debugging race conditions you didn't write.",
  },
  {
    icon: 'msg',
    title: 'Customers hear back when their bugs are fixed.',
    desc: 'Loop closure drives CSAT and converts 1-star reviews into 3+ star updates.',
  },
  {
    icon: 'shield',
    title: 'Fixes ship verified, not assumed.',
    desc: 'Every patch runs against your full test suite — no "fix" that reintroduces a crash next release.',
  },
  {
    icon: 'chart',
    title: 'Stay under the Play bad-behavior threshold.',
    desc: 'Apps crashing on more than 1.09% of user-perceived sessions get demoted. Ube keeps you under the line.',
  },
  {
    icon: 'star',
    title: 'Higher app-store ratings.',
    desc: 'Faster fixes plus customer follow-up means users update their reviews. The flywheel reverses.',
  },
  {
    icon: 'rocket',
    title: 'Sprint cycles go to features, not firefighting.',
    desc: 'Net new product velocity goes up. The team ships the work they were hired to ship.',
  },
];

// Inline SVG path bodies — kept compact since they're tiny and there are only 6.
const icons: Record<string, string> = {
  clock: '<circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>',
  msg: '<path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/>',
  shield: '<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>',
  chart: '<line x1="12" y1="20" x2="12" y2="10"/><line x1="18" y1="20" x2="18" y2="4"/><line x1="6" y1="20" x2="6" y2="16"/>',
  star: '<polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>',
  rocket: '<path d="M4.5 16.5c-1.5 1.26-2 5-2 5s3.74-.5 5-2c.71-.84.7-2.13-.09-2.91a2.18 2.18 0 0 0-2.91-.09z"/><path d="M12 15l-3-3a22 22 0 0 1 2-3.95A12.88 12.88 0 0 1 22 2c0 2.72-.78 7.5-6 11a22.35 22.35 0 0 1-4 2z"/><path d="M9 12H4s.55-3.03 2-4c1.62-1.08 5 0 5 0"/><path d="M12 15v5s3.03-.55 4-2c1.08-1.62 0-5 0-5"/>',
};
---
<section class="section" style="background:var(--canvas)">
  <div class="container">
    <div class="sec-head reveal">
      <div class="eyebrow">Outcomes</div>
      <h2 class="display-lg">What it actually changes.</h2>
    </div>

    <div class="benefit-stat reveal">
      <div class="num">10–30%</div>
      <div class="cap">of your team's engineering time reclaimed — back into features, not firefighting.</div>
    </div>

    <div class="benefits-grid">
      {benefits.map((b) => (
        <article class="b-card reveal">
          <span class="icon-tile">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" set:html={icons[b.icon]} />
          </span>
          <h3 class="title-md">{b.title}</h3>
          <p>{b.desc}</p>
        </article>
      ))}
    </div>
  </div>
</section>
