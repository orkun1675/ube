---
// Top navigation — static markup rendered server-side on every route
// (spec 0005). Replaces the previous React `TopNav` island; behaviors that
// genuinely need a client are attached by the colocated `nav.client.ts`:
// scroll-class toggle, mobile-menu open/close (with body-scroll lock and
// Esc dismissal), and the "Request access" button clicks that route into
// `openRequestAccess('nav')` from the nano store.
//
// Active route + landing-page anchor target are derived from
// `Astro.url.pathname` so no prop drilling from BaseLayout is required.
// Mobile menu lives inline (no React portal) — `.mobile-menu` is
// `position: fixed; inset: 0; z-index: 1000` in styles.css, which trumps
// the .topnav backdrop-filter without needing `createPortal` to `<body>`.
import Wordmark from "@/components/Wordmark.astro"
import { TWEAK_DEFAULTS } from "@/data/tweak-defaults"

const wordmarkAccent = TWEAK_DEFAULTS.wordmarkAccent

const pathname = Astro.url.pathname
const isLandingPage = pathname === "/"
// `/maintainer` redirects to `/`, so on the landing page the Maintainer
// nav item is "where we are". Other routes (terms, privacy) don't have a
// nav-center entry — nothing highlights.
const maintainerActive = isLandingPage
const wordmarkHref = isLandingPage ? "#top" : "/"
---

<nav class="topnav" data-nav>
  <div class="container topnav-inner topnav-inner-positioned">
    <a href={wordmarkHref} class="wordmark-link">
      <Wordmark accent={wordmarkAccent} size={30} />
    </a>

    <div class="nav-center">
      <span class="nav-link coming-soon">
        Publisher
        <span class="tooltip">Coming soon</span>
      </span>
      <a
        href="/"
        class:list={["nav-link", { active: maintainerActive }]}
      >
        Maintainer
      </a>
      <span class="nav-link coming-soon">
        Pricing
        <span class="tooltip">Coming soon</span>
      </span>
    </div>

    <div class="nav-right-actions">
      <button type="button" class="btn btn-primary btn-sm" data-nav-cta>
        Request access
      </button>
    </div>

    <button
      type="button"
      class="menu-btn"
      data-nav-menu-open
      aria-label="Open menu"
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      <svg
        width="18"
        height="18"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        aria-hidden="true"
      >
        <path d="M3 6h18M3 12h18M3 18h18" stroke-linecap="round" />
      </svg>
    </button>
  </div>
</nav>

<div
  id="mobile-menu"
  class="mobile-menu"
  role="dialog"
  aria-modal="true"
  aria-label="Site menu"
  hidden
  data-nav-menu
>
  <div class="mobile-menu-header">
    <Wordmark accent={wordmarkAccent} size={28} />
    <button
      type="button"
      class="menu-btn"
      data-nav-menu-close
      aria-label="Close menu"
    >
      <span class="close-icon">
        <svg
          width="18"
          height="18"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          aria-hidden="true"
        >
          <path d="M12 5v14M5 12h14"></path>
        </svg>
      </span>
    </button>
  </div>
  <div class="mobile-menu-links">
    <span class="mobile-menu-link coming-soon">
      Publisher <span class="mobile-menu-tag">soon</span>
    </span>
    <a
      href="/"
      class:list={["mobile-menu-link", { active: maintainerActive }]}
      data-nav-menu-link
    >
      Maintainer
    </a>
    <span class="mobile-menu-link coming-soon">
      Pricing <span class="mobile-menu-tag">soon</span>
    </span>
  </div>
  <button
    type="button"
    class="btn btn-primary mobile-menu-cta"
    data-nav-cta
    data-nav-menu-cta
  >
    Request access
    <svg
      width="14"
      height="14"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="1.8"
      stroke-linecap="round"
      stroke-linejoin="round"
      aria-hidden="true"
    >
      <path d="M5 12h14M13 5l7 7-7 7"></path>
    </svg>
  </button>
</div>

<script src="./nav.client.ts"></script>

<style>
  /* Establish a positioning context for absolutely-positioned descendants
     of the nav (e.g. the `.tooltip` on coming-soon links). */
  .topnav-inner-positioned {
    position: relative;
  }
  /* The wordmark sits inside this anchor; suppress the default link
     underline so only the brand mark shows. */
  .wordmark-link {
    text-decoration: none;
  }
  /* The mobile close button reuses the `+` SVG and rotates it 45° to form
     an ×. `inline-flex` keeps the SVG's box from inheriting line-box
     baseline alignment, which would otherwise nudge the rotated cross
     off-center inside the button. */
  .close-icon {
    display: inline-flex;
    transform: rotate(45deg);
  }

  /* Top nav */
  .topnav {
    position: sticky;
    top: 0;
    z-index: 50;
    background: rgba(30, 30, 34, 0.78);
    backdrop-filter: blur(14px) saturate(140%);
    -webkit-backdrop-filter: blur(14px) saturate(140%);
    border-bottom: 1px solid transparent;
    transition:
      border-color 200ms ease-out,
      background 200ms ease-out;
  }
  /* Edge-fading hairline + shadow underneath the nav */
  .topnav::after {
    content: "";
    position: absolute;
    left: 0;
    right: 0;
    top: 100%;
    height: 24px;
    pointer-events: none;
    background:
      linear-gradient(to bottom, rgba(0, 0, 0, 0.35), rgba(0, 0, 0, 0)),
      linear-gradient(to bottom, var(--hairline-soft), var(--hairline-soft)) top /
      100% 1px no-repeat;
    -webkit-mask-image: linear-gradient(
      to right,
      transparent 0%,
      #000 18%,
      #000 82%,
      transparent 100%
    );
    mask-image: linear-gradient(
      to right,
      transparent 0%,
      #000 18%,
      #000 82%,
      transparent 100%
    );
    opacity: 0.6;
    transition: opacity 220ms ease-out;
  }
  .topnav.scrolled {
    background: rgba(30, 30, 34, 0.94);
  }
  .topnav.scrolled::after {
    opacity: 1;
    background:
      linear-gradient(to bottom, rgba(0, 0, 0, 0.55), rgba(0, 0, 0, 0)),
      linear-gradient(to bottom, var(--hairline-strong), var(--hairline-strong))
      top / 100% 1px no-repeat;
  }
  .topnav-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 72px;
  }
  .nav-center {
    display: flex;
    align-items: center;
    gap: 24px;
    position: absolute;
    left: 50%;
    transform: translateX(-50%);
  }
  .nav-link {
    font-size: 14px;
    font-weight: 500;
    color: var(--body);
    text-decoration: none;
    position: relative;
    padding: 6px 0;
  }
  .nav-link:hover {
    color: var(--ink);
  }
  .nav-link.active {
    color: var(--ink);
  }
  .nav-link.active::after {
    content: "";
    position: absolute;
    left: 50%;
    bottom: -3px;
    transform: translateX(-50%);
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: var(--mark);
  }

  /* Nav right cluster — flex-by-class so the @media hide on phone wins
     over potential inline display values. */
  .nav-right-actions {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  /* Mobile menu trigger */
  .menu-btn {
    display: none;
    background: transparent;
    border: 1px solid var(--hairline-strong);
    border-radius: var(--r-md);
    width: 40px;
    height: 40px;
    color: var(--ink);
    cursor: pointer;
    align-items: center;
    justify-content: center;
  }
  @media (max-width: 768px) {
    .nav-center {
      display: none;
    }
    .menu-btn {
      display: inline-flex;
    }
    .nav-right-actions {
      display: none;
    }
  }

  /* Mobile menu (rendered as a sibling of .topnav at the body level
     so backdrop-filter on .topnav doesn't trap position:fixed inside the
     nav). Toggled via the `hidden` attribute by nav.client.ts — the explicit
     `[hidden]` rule below is required because our `display: flex` on
     `.mobile-menu` otherwise wins over the UA's `display: none`. */
  .mobile-menu {
    position: fixed;
    inset: 0;
    z-index: 1000;
    background: #0e0e11;
    /* Solid first; layer a subtle dot grid for texture */
    background-image: radial-gradient(
      rgba(255, 255, 255, 0.08) 1px,
      transparent 1px
    );
    background-size: 28px 28px;
    background-color: #0e0e11;
    display: flex;
    flex-direction: column;
    padding: 20px 24px 32px;
    gap: 28px;
    animation: mobileMenuIn 220ms cubic-bezier(0.22, 0.61, 0.36, 1);
  }
  .mobile-menu[hidden] {
    display: none;
  }
  @keyframes mobileMenuIn {
    from {
      opacity: 0;
      transform: translateY(-4px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  .mobile-menu-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 40px;
  }
  .mobile-menu-links {
    display: flex;
    flex-direction: column;
    gap: 4px;
    margin-top: 12px;
  }
  .mobile-menu-link {
    font-family: var(--font-sans);
    font-size: 28px;
    font-weight: 500;
    letter-spacing: -0.5px;
    color: var(--ink);
    text-decoration: none;
    padding: 14px 0;
    border-bottom: 1px solid var(--hairline-soft);
    display: flex;
    align-items: baseline;
    gap: 12px;
  }
  /* `.coming-soon` is a global utility class — wrap in :global() so Astro
     doesn't try to scope its selector with this component's cid attribute
     (the element still gets the cid, but the class selector matches the
     global token directly). */
  .mobile-menu-link:global(.coming-soon) {
    color: var(--muted);
    cursor: not-allowed;
  }
  .mobile-menu-link.active {
    color: var(--ink);
  }
  .mobile-menu-link.active::before {
    content: "";
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--accent);
    display: inline-block;
    align-self: center;
  }
  .mobile-menu-tag {
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.6px;
    text-transform: uppercase;
    color: var(--muted-soft);
    padding: 3px 7px;
    border: 1px solid var(--hairline-strong);
    border-radius: var(--r-pill);
    align-self: center;
  }
  .mobile-menu-cta {
    margin-top: auto;
    width: 100%;
    justify-content: center;
    height: 52px;
    font-size: 15px;
  }

  /* Top nav — tighten height & wordmark on phone. `.wordmark` is owned by
     Wordmark.astro, so wrap in :global() to skip cid-attribute scoping. */
  @media (max-width: 640px) {
    .topnav-inner {
      height: 60px;
    }
    .topnav-inner :global(.wordmark) {
      font-size: 24px;
    }
  }
</style>
