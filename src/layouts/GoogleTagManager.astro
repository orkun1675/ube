---
// Google Tag Manager loader. The container fans out to ad platforms (Reddit
// today; Google Ads / Meta / LinkedIn later) — see docs/gtm-reddit-setup.md.
//
// Mirrors Amplitude.astro: the snippet is injected dynamically and only runs
// on ube.dev (or a subdomain), so on localhost GTM never loads — no
// dataLayer, no tags, no network, no noise. Escape hatch for local
// verification / GTM Preview mode: append ?gtm=1.
//
// Why a runtime hostname gate rather than a static <script id=...>: the same
// static build is served from localhost during `npm run preview`, and GTM
// would otherwise fire there too. The companion <noscript> in BaseLayout is
// gated at build time (import.meta.env.PROD) instead, since it can't run JS
// to check the host.
import { GTM_CONTAINER_ID } from "@/constants"
---

<script is:inline define:vars={{ GTM_CONTAINER_ID }}>
  {
    const h = location.hostname
    const enabled =
      h === "ube.dev" ||
      h.endsWith(".ube.dev") ||
      location.search.includes("gtm=1")
    if (enabled) {
      // Standard GTM bootstrap, gated. We use the default `dataLayer` global
      // name, so the snippet's `&l=` custom-name handling is dropped.
      window.dataLayer = window.dataLayer || []
      window.dataLayer.push({ "gtm.start": new Date().getTime(), event: "gtm.js" })
      const j = document.createElement("script")
      j.async = true
      j.src = "https://www.googletagmanager.com/gtm.js?id=" + GTM_CONTAINER_ID
      document.head.appendChild(j)
    }
  }
</script>
