---
// Amplitude Analytics + Session Replay (Unified Script — Amplitude CDN).
// The script tag is injected dynamically so it only loads on ube.dev
// (or a subdomain). Escape hatch for local verification: ?amplitude=1.
// A static <script src> would fire tracking + session replay
// immediately on parse — the Unified Script auto-initializes from its
// dashboard config the moment it executes, so an onload-time gate
// doesn't actually stop anything.
//
// On script load, `init()` is called explicitly so SDK config stays
// in version control instead of the Amplitude dashboard's Remote
// Config — `defaultTracking` is intentionally omitted (superseded by
// `autocapture`).
const AMPLITUDE_API_KEY = "7fdbc1ae75a64eb50d90f29ac9721390"
---

<script is:inline define:vars={{ AMPLITUDE_API_KEY }}>
  {
    const h = location.hostname
    const enabled =
      h === "ube.dev" ||
      h.endsWith(".ube.dev") ||
      location.search.includes("amplitude=1")
    if (enabled) {
      const s = document.createElement("script")
      s.src = `https://cdn.amplitude.com/script/${AMPLITUDE_API_KEY}.js`
      s.async = true
      s.onload = () => {
        window.amplitude?.init?.(AMPLITUDE_API_KEY, {
          autocapture: true,
          fetchRemoteConfig: true,
        })
      }
      document.head.appendChild(s)
    }
  }
</script>
