---
// Amplitude Analytics + Session Replay (Unified Script — Amplitude CDN).
// The script tag is injected dynamically so it only loads on ube.dev
// (or a subdomain). Escape hatch for local verification: ?amplitude=1.
// A static <script src> would fire tracking + session replay
// immediately on parse — the Unified Script auto-initializes from its
// dashboard config the moment it executes, so an onload-time gate
// doesn't actually stop anything.
//
// On script load, an enrichment plugin rewrites `[Amplitude] Page
// Title` from the 50+ char SEO `<title>` (e.g. "Ube Publisher —
// Mobile App Distribution Orchestrator") to a short, route-keyed
// label so the event feed stays readable. Applies to every
// autocapture event that carries the property (page views, element
// clicks, form interactions). Then `init()` is called explicitly
// so SDK config stays in version control instead of the Amplitude
// dashboard's Remote Config — `defaultTracking` is intentionally
// omitted (superseded by `autocapture`).
const AMPLITUDE_API_KEY = "7fdbc1ae75a64eb50d90f29ac9721390"
---

<script is:inline define:vars={{ AMPLITUDE_API_KEY }}>
  {
    const h = location.hostname
    const enabled =
      h === "ube.dev" ||
      h.endsWith(".ube.dev") ||
      location.search.includes("amplitude=1")
    if (enabled) {
      const s = document.createElement("script")
      s.src = `https://cdn.amplitude.com/script/${AMPLITUDE_API_KEY}.js`
      s.async = true
      s.onload = () => {
        const SHORT_PAGE_TITLES = {
          "/": "Publisher",
          "/publisher/": "Publisher",
          "/maintainer/": "Maintainer",
          "/pricing/": "Pricing",
          "/privacy-policy/": "Privacy Policy",
          "/terms-of-service/": "Terms of Service",
        }
        window.amplitude?.add?.({
          name: "ube-short-page-title",
          type: "enrichment",
          setup: async () => undefined,
          execute: async (event) => {
            const short = SHORT_PAGE_TITLES[location.pathname]
            if (short && event.event_properties) {
              event.event_properties["[Amplitude] Page Title"] = short
            }
            return event
          },
        })
        window.amplitude?.init?.(AMPLITUDE_API_KEY, {
          autocapture: true,
          fetchRemoteConfig: true,
        })
      }
      document.head.appendChild(s)
    }
  }
</script>
