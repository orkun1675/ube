---
// Shared shell for every page. Strict props-only API (ADR 0001):
// every <head> tag is derived from props passed by the page frontmatter.
// No per-page meta duplication.
//
// JSON-LD is rendered via `set:html` when the `jsonLd` prop is provided —
// pages stringify their schema and pass the result through here.
//
// The Request Access modal is mounted at the bottom (ADR 0002) and
// hydrates during browser idle time on every route so any island's
// `openRequestAccess(source)` call wires through the nano store to a
// shared modal instance.
// The modal is closed by default and opens via the nanostore from vanilla
// CTA scripts; if a user clicks before React hydrates, the store update is
// preserved and the modal renders open on first paint after hydration.
//
// Footer is on every route (per spec 0003) so it lives here, after the
// page <slot/> and before the modal island. Nav joined Footer here in
// spec 0005 — it's also on every route and is now static `.astro` markup
// (interactive bits in `components/nav/nav.client.ts`).
//
// Slice 0008 dissolved the per-page React app islands (LandingPageApp /
// TermsPageApp / PrivacyPageApp), so two things that used to live inside
// them are hoisted here:
//   - The engagement + scroll-depth trackers run from a plain
//     `<script src="./page-tracking.client.ts">` so terms/privacy don't
//     need any top-level React on the page.
//   - The dev-only TweaksPanel self-mounts from `src/dev/tweaks-panel.client.tsx`.
//     Its `<script>` element is gated behind `import.meta.env.DEV` and
//     omitted from production HTML entirely — so neither the script tag
//     nor any URL under `src/dev/` is emitted in the prod build (ADR 0003).
//     BaseLayout itself stays free of any JS import from `src/dev/*`.
import { RequestAccessIsland } from "@/components/modals/RequestAccessIsland"
import Nav from "@/components/nav/Nav.astro"
import Footer from "@/components/sections/Footer.astro"

// Self-hosted variable fonts (cuts ~180ms median LCP vs. the Google CDN).
// One file per family covers every weight we use — see styles.css where
// "Inter Variable" / "JetBrains Mono Variable" are wired into --font-sans
// / --font-mono.
import "@fontsource-variable/inter"
import "@fontsource-variable/jetbrains-mono"
import "@/styles.css"

export interface Props {
  title: string
  description: string
  // Optional override. When omitted, derived from Astro.site + Astro.url.pathname
  // so every route has a canonical without duplicating the host string.
  canonical?: string
  ogImage?: string
  ogType?: string
  jsonLd?: object | object[]
  // Optional accent-mode flag rendered as `body[data-accent-mode]`. Only
  // the landing page passes this (split mode reroutes structural marks to
  // the coconut secondary — see styles.css `body[data-accent-mode="split"]`).
  // Pre-spec-0008 the landing-page React island set this on `document.body`
  // at runtime; baking it into the server-rendered <body> attribute keeps
  // the rule active without shipping a JS thunk.
  accentMode?: string
}

const {
  title,
  description,
  canonical = new URL(Astro.url.pathname, Astro.site).href,
  ogImage = new URL("/assets/social/og-image.jpg", Astro.site).href,
  ogType = "website",
  jsonLd,
  accentMode,
} = Astro.props

// Always render an array — keeps the loop trivial whether the page passes
// one schema or many.
const jsonLdBlocks = jsonLd ? (Array.isArray(jsonLd) ? jsonLd : [jsonLd]) : []
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <!-- Favicon: off-white "u" between purple brackets on charcoal —
         same tokens as the live site, shipped as one opaque tile so it
         reads identically on light and dark tabs. The .ico ships at /
         for legacy bookmark managers / RSS readers / embed previews that
         still hardcode /favicon.ico; the PNGs cover modern browsers and
         iOS home-screen. -->
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link
      rel="icon"
      type="image/png"
      sizes="192x192"
      href="/assets/favicons/favicon.png"
    />
    <link
      rel="apple-touch-icon"
      sizes="180x180"
      href="/assets/favicons/apple-touch-icon.png"
    />
    <link rel="sitemap" type="application/xml" href="/sitemap-index.xml" />

    <!-- Open Graph / social preview -->
    <meta property="og:locale" content="en_US" />
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content="Ube" />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta
      property="og:image:alt"
      content="Ube — App maintenance, on autopilot."
    />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Browser chrome tint (matches --canvas in styles.css) -->
    <meta name="theme-color" content="#1e1e22" />

    <!-- Web app manifest for share-to-homescreen on mobile -->
    <link rel="manifest" href="/site.webmanifest" />

    <!-- Structured data for search + AI answer engines. Kept in raw HTML
         (rather than injected by React) so non-JS crawlers can read them. -->
    {
      jsonLdBlocks.map((block) => (
        <script
          is:inline
          type="application/ld+json"
          set:html={JSON.stringify(block, null, 2)}
        />
      ))
    }

    <!-- Fonts: self-hosted via @fontsource-variable (imported in this
         layout's frontmatter). The variable WOFF2 ships from the same
         origin via Vite's asset pipeline — no render-blocking call to
         fonts.googleapis.com. We don't add a <link rel="preload"> here
         because Vite fingerprints the asset paths per build, so a
         hardcoded preload href would 404 on every rebuild. -->

    <!-- reCAPTCHA v3 (used by Basin for spam protection on the request-access form)
         is lazy-loaded from the modal — see src/components/modals/RequestAccessModal.tsx.
         Loading it up-front blocks render and pulls Google trackers for every visitor. -->

    <!-- Amplitude Analytics + Session Replay (Unified Script — Amplitude CDN).
         Only initialized on ube.dev (or a subdomain). On localhost the snippet
         stub installs but `init` is skipped — escape hatch: ?amplitude=1 -->
    <link rel="preconnect" href="https://cdn.amplitude.com" />
    <script is:inline>
      {
        window.initUbeAmplitude = () => {
          const h = location.hostname
          const enabled =
            h === "ube.dev" ||
            h.endsWith(".ube.dev") ||
            location.search.includes("amplitude=1")
          if (!enabled || !window.amplitude) return

          if (window.amplitude.add && window.sessionReplay?.plugin) {
            window.amplitude.add(window.sessionReplay.plugin({ sampleRate: 1 }))
          }
          window.amplitude.init?.("7fdbc1ae75a64eb50d90f29ac9721390", {
            defaultTracking: true,
            autocapture: true,
            fetchRemoteConfig: true,
          })
        }
      }
    </script>
    <script
      is:inline
      async
      src="https://cdn.amplitude.com/script/7fdbc1ae75a64eb50d90f29ac9721390.js"
      onload="window.initUbeAmplitude?.()"
    ></script>
  </head>
  <body data-accent-mode={accentMode}>
    <!-- The page itself acts as a "curtain" that lifts off the wordmark
         below. Everything that scrolls naturally with the page goes inside
         `.page-content`; the fixed wordmark is a sibling, pinned to the
         viewport bottom and hidden behind the curtain until it scrolls up. -->
    <div class="page-content">
      <Nav />
      <slot />
      <Footer />
    </div>
    <div class="footer-curtain" aria-hidden="true">
      <span class="footer-curtain-text">ube</span>
    </div>
    <RequestAccessIsland client:idle />
    {
      // Dev-only tweaks panel — self-mounts via its own React root. The
      // script element is omitted entirely in production builds, so no
      // dev-directory URL appears in the production HTML or bundle
      // (ADR 0003 invariant).
      import.meta.env.DEV && (
        <script is:inline type="module" src="/src/dev/tweaks-panel.client.tsx"></script>
      )
    }
    <script src="./page-tracking.client.ts"></script>
  </body>
</html>

<style>
  /* Amplitude-style "curtain raise" reveal: a giant wordmark is pinned to
     the bottom of the viewport for the whole session — but it sits behind
     `.page-content`, which carries the canvas background and a higher
     z-index, so the user never sees it during normal scroll. The page
     has extra empty body below it sized to the wordmark; as the user
     scrolls to the end, the page lifts up off the wordmark like a
     curtain, and the wordmark settles into view from the bottom.

     The wordmark is `position: fixed` so it stays pinned regardless of
     scroll position — `position: sticky` would work too, but `body
     { overflow-x: hidden }` in styles.css makes body a scroll container
     and breaks viewport-relative sticky.

     `--wordmark-size` is shared between the rendered wordmark and the
     page's bottom margin so the scroll offset always matches the
     wordmark's actual footprint — no manual tuning when the size or
     viewport changes. */
  body {
    --wordmark-size: clamp(5rem, 26vw, 22rem);
  }
  /* On mobile, 26vw leaves the wordmark taking only ~50% of the viewport
     width — bump the vw multiplier so "ube" fills most of the screen. */
  @media (max-width: 640px) {
    body {
      --wordmark-size: 46vw;
    }
  }

  .page-content {
    position: relative;
    z-index: 2;
    background: var(--canvas);
    /* Bottom margin scales with the wordmark's font-size so the scroll
       distance always matches what's revealed. */
    margin-bottom: calc(var(--wordmark-size) * 1.06);
    /* Soft drop shadow at the bottom edge — reads as the lifting page
       casting a shadow onto the wordmark below. */
    box-shadow: 0 28px 40px -24px rgba(0, 0, 0, 0.7);
  }

  .footer-curtain {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 1;
    display: flex;
    align-items: flex-end;
    justify-content: center;
    overflow: hidden;
    padding: 0 16px 16px;
    pointer-events: none;
    user-select: none;
  }

  .footer-curtain-text {
    display: block;
    font-family: var(--font-sans);
    font-weight: 700;
    letter-spacing: -0.06em;
    /* Sized to fill most of the viewport WIDTH at common breakpoints
       without dominating the viewport's height when the curtain lifts.
       `ube` is short (3 chars), so a smaller vw multiplier than a longer
       wordmark would use. */
    font-size: var(--wordmark-size);
    line-height: 0.82;
    /* Top is dimmed, bottom is full ink — the gradient still reads as if
       the curtain above is shadowing the top of the wordmark, reinforcing
       the box-shadow on `.page-content`. */
    background: linear-gradient(
      180deg,
      rgba(245, 245, 242, 0.5) 0%,
      rgba(245, 245, 242, 0.8) 40%,
      rgba(245, 245, 242, 0.95) 75%,
      var(--ink) 100%
    );
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
    /* Negative letter-spacing pulls the right side of the trailing "e"
       past the layout box; `overflow: hidden` on the curtain then clips
       the glyph. Pad the inline-end to give it room. The 0.04em padding
       on the bottom is for the descender (no descender in "ube", but
       protects font swaps). */
    padding: 0 0.08em 0.04em 0;
  }
</style>
