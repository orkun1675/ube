---
// pages/index.astro — homepage.
import BaseLayout    from '../layouts/BaseLayout.astro';
import Hero          from '../components/Hero.astro';
import Problems      from '../components/Problems.astro';
import HowItWorks    from '../components/HowItWorks.astro';
import Benefits      from '../components/Benefits.astro';
import Faq           from '../components/Faq.astro';
import FinalCta      from '../components/FinalCta.astro';

// Page-specific stylesheet. Astro bundles this only into the index route.
import '../styles/mockups.css';
---
<BaseLayout
  title="Ube — Maintenance, on autopilot"
  description="Ube reads your crash feeds, error logs, dependency upgrades, and user reviews — then triages, reproduces, fixes, and ships."
  currentProduct="maintainer"
>
  <Hero />
  <Problems />
  <HowItWorks />
  <Benefits />
  <Faq />
  <FinalCta />
</BaseLayout>
