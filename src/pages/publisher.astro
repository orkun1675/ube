---
import { TWEAK_DEFAULTS } from "@/data/tweak-defaults"
import { CARD_TONES, getUbe } from "@/lib/palette"
import FinalCta from "@/components/publisher/sections/FinalCta.astro"
import Hero from "@/components/publisher/sections/Hero.astro"
import Insights from "@/components/publisher/sections/Insights.astro"
import Loop from "@/components/publisher/sections/Loop.astro"
import Moat from "@/components/publisher/sections/Moat.astro"
import Problems from "@/components/publisher/sections/Problems.astro"
import Stack from "@/components/publisher/sections/Stack.astro"
import BaseLayout from "@/layouts/BaseLayout.astro"
import {
  buildBreadcrumbSchema,
  buildJsonLdGraph,
  buildOrganizationSchema,
  buildPublisherSchema,
  buildWebPageSchema,
  buildWebsiteSchema,
  schemaIds,
} from "@/lib/schema"

const title = "Ube Publisher — Mobile App Distribution Orchestrator"
const description =
  "Ube Publisher sets up analytics, attribution, dashboards, paid ads, creatives, and A/B tests so app builders learn what to improve before scaling spend."

const ube = getUbe(TWEAK_DEFAULTS.accent)
const accent = `oklch(${ube.L} ${ube.C} ${ube.H})`
const accentHover = `oklch(${Math.min(0.72, ube.L + 0.1)} ${ube.C} ${ube.H})`
const accentSoft = `oklch(${Math.max(0.18, ube.L - 0.26)} ${Math.max(0.06, ube.C - 0.08)} ${ube.H})`
const accentTint = `oklch(${ube.L} ${ube.C} ${ube.H} / 0.14)`
const cardTone = CARD_TONES[TWEAK_DEFAULTS.cardTone] ?? CARD_TONES["warm"]
const cardBg = cardTone?.bg ?? "#1d1b15"
const cardBorder = cardTone?.border ?? "#2a2720"

const dateModified = new Date().toISOString()
const siteUrl = new URL("/", Astro.site).href
const publisherUrl = new URL("/publisher/", Astro.site).href
const ids = schemaIds(Astro.site)

const jsonLd = buildJsonLdGraph([
  buildOrganizationSchema(Astro.site, dateModified),
  buildWebsiteSchema(Astro.site),
  buildPublisherSchema(Astro.site, dateModified, description),
  buildWebPageSchema(Astro.site, {
    pageUrl: publisherUrl,
    title,
    description,
    dateModified,
    aboutId: ids.publisherId,
  }),
  buildBreadcrumbSchema(publisherUrl, [
    { name: "Ube", url: siteUrl },
    { name: "Ube Publisher", url: publisherUrl },
  ]),
])
---

<BaseLayout
  title={title}
  description={description}
  jsonLd={jsonLd}
  accentMode="split"
>
  <style
    define:vars={{ accent, accentHover, accentSoft, accentTint, cardBg, cardBorder }}
  >
    main {
      --accent-hover: var(--accentHover);
      --accent-soft: var(--accentSoft);
      --accent-tint: var(--accentTint);
      --card-bg: var(--cardBg);
      --card-border: var(--cardBorder);
      background: var(--canvas);
    }
  </style>

  <main class="publisher-page">
    <Hero />
    <Problems />
    <Stack />
    <Loop />
    <Insights />
    <Moat />
    <FinalCta />
  </main>
</BaseLayout>
