---
// pages/publisher.astro — stub for the second product (Publisher).
// Per the brief: Publisher is on the roadmap, not yet described. Treat this
// as a placeholder route that will fill out once Publisher scope is defined.
import BaseLayout from '../layouts/BaseLayout.astro';
import FinalCta   from '../components/FinalCta.astro';
---
<BaseLayout
  title="Ube Publisher — Coming soon"
  description="Ube Publisher is on the roadmap. Request early access to be notified when it ships."
  currentProduct="publisher"
>
  <section class="section" style="padding-top:160px;text-align:center">
    <div class="container">
      <div class="eyebrow" style="margin-bottom:16px">Ube Publisher</div>
      <h1 class="display-mega" style="margin:0 auto 24px;max-width:18ch;text-wrap:balance">Ship faster.<br /><span style="color:var(--accent)">Reach more users.</span></h1>
      <p class="body-md" style="max-width:48ch;margin:0 auto 32px;font-size:17px">
        Publisher is the second half of Ube — focused on getting your work in front of the people who'll use it. We'll share more soon.
      </p>
      <button class="btn btn-primary js-open-modal">Request Access</button>
    </div>
  </section>

  <FinalCta
    headline="Want a heads-up when Publisher ships?"
    body="Tell us which product matters more — Maintainer, Publisher, or both — and we'll keep you in the loop."
  />
</BaseLayout>
