---
import { TWEAK_DEFAULTS } from "@/data/tweak-defaults"
import { CARD_TONES, getUbe } from "@/lib/palette"
import FinalCta from "@/components/publisher/sections/FinalCta.astro"
import Hero from "@/components/publisher/sections/Hero.astro"
import Insights from "@/components/publisher/sections/Insights.astro"
import Loop from "@/components/publisher/sections/Loop.astro"
import Moat from "@/components/publisher/sections/Moat.astro"
import Problems from "@/components/publisher/sections/Problems.astro"
import Stack from "@/components/publisher/sections/Stack.astro"
import BaseLayout from "@/layouts/BaseLayout.astro"

const title = "Ube Publisher — Mobile App Distribution Orchestrator"
const description =
  "Ube Publisher sets up analytics, attribution, dashboards, paid ads, creatives, and A/B tests so app builders learn what to improve before scaling spend."

const ube = getUbe(TWEAK_DEFAULTS.accent)
const accent = `oklch(${ube.L} ${ube.C} ${ube.H})`
const accentHover = `oklch(${Math.min(0.72, ube.L + 0.1)} ${ube.C} ${ube.H})`
const accentSoft = `oklch(${Math.max(0.18, ube.L - 0.26)} ${Math.max(0.06, ube.C - 0.08)} ${ube.H})`
const accentTint = `oklch(${ube.L} ${ube.C} ${ube.H} / 0.14)`
const cardTone = CARD_TONES[TWEAK_DEFAULTS.cardTone] ?? CARD_TONES["warm"]
const cardBg = cardTone?.bg ?? "#1d1b15"
const cardBorder = cardTone?.border ?? "#2a2720"

const dateModified = new Date().toISOString()
const siteUrl = new URL("/", Astro.site).href
const publisherUrl = new URL("/publisher/", Astro.site).href
const pricingUrl = new URL("/pricing/", Astro.site).href
const orgId = new URL("/#organization", Astro.site).href
const websiteId = new URL("/#website", Astro.site).href
const publisherId = new URL("/publisher/#ube-publisher", Astro.site).href

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "SoftwareApplication",
    "@id": publisherId,
    name: "Ube Publisher",
    url: publisherUrl,
    applicationCategory: "BusinessApplication",
    operatingSystem: "Web",
    description,
    dateModified,
    isPartOf: { "@id": websiteId },
    creator: {
      "@type": "Organization",
      "@id": orgId,
      name: "Chunky Tofu Studios, LLC",
      url: siteUrl,
    },
    featureList: [
      "Audits and instruments mobile apps with analytics and attribution SDKs",
      "Sets up dashboards, MMP imports, SKAdNetwork schema, and event forwarding",
      "Creates and tests ad creatives across paid acquisition channels",
      "Finds drop-off points and recommends retention and monetization experiments",
      "Runs A/B tests through Firebase or RevenueCat with approval gates",
      "Scales budget only after retention, monetization, and campaign math improve",
    ],
    offers: {
      "@type": "Offer",
      name: "Maintainer + Publisher early access",
      url: pricingUrl,
      price: "100",
      priceCurrency: "USD",
      availability: "https://schema.org/PreOrder",
      priceSpecification: {
        "@type": "UnitPriceSpecification",
        price: "100",
        priceCurrency: "USD",
        unitText: "per app per month",
      },
    },
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
      {
        "@type": "ListItem",
        position: 1,
        name: "Ube Maintainer",
        item: siteUrl,
      },
      {
        "@type": "ListItem",
        position: 2,
        name: "Ube Publisher",
        item: publisherUrl,
      },
    ],
  },
]
---

<BaseLayout
  title={title}
  description={description}
  jsonLd={jsonLd}
  accentMode="split"
>
  <style
    define:vars={{ accent, accentHover, accentSoft, accentTint, cardBg, cardBorder }}
  >
    main {
      --accent-hover: var(--accentHover);
      --accent-soft: var(--accentSoft);
      --accent-tint: var(--accentTint);
      --card-bg: var(--cardBg);
      --card-border: var(--cardBorder);
      background: var(--canvas);
    }
  </style>

  <main class="publisher-page">
    <Hero />
    <Problems />
    <Stack />
    <Loop />
    <Insights />
    <Moat />
    <FinalCta />
  </main>
</BaseLayout>
